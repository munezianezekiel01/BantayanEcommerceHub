@model MyEccomerce.Models.Order

<div class="container mt-5">
    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Assign Rider para sa Order #@Model.OrderId</h5>
        </div>
        <div class="card-body">
            <form asp-action="AssignRider" method="post">
                <input type="hidden" name="OrderId" value="@Model.OrderId" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Pili og Rider:</label>
                    <select name="RiderId" class="form-select" asp-items="ViewBag.RiderList">
                        <option value="">-- Pilia ang Rider nga i-assign --</option>
                    </select>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4 rounded-pill">Confirm Assignment</button>
                    <a asp-action="Index" class="btn btn-light px-4 rounded-pill">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
