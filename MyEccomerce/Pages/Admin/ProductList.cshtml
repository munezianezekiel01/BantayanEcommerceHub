@model IEnumerable<MyEccomerce.Models.Product>
@using System.Text.Encodings.Web
@using System.Web

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Product Testing List";
}

<div class="container-fluid px-4 mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h1 class="fw-bold text-dark display-6 mb-1">🛠️ Product Management</h1>
            <p class="text-muted fs-5 mb-0">Testing Mode: I-verify ug i-manage ang imong mga produkto sa database.</p>
        </div>
        <a href="@Url.Action("AddProduct", "Admin")" class="btn btn-primary btn-lg shadow-sm px-4">
            <i class="fas fa-plus me-2"></i> Add New Product
        </a>
    </div>

    <div class="card shadow border-0 mb-5">
        <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
            <span class="fs-5 fw-semibold">
                <i class="fas fa-table me-2 text-warning"></i> Products Registry
            </span>
            <span class="badge bg-warning text-dark fs-6 px-3 py-2 fw-bold rounded-pill">
                Total Items: @Model.Count()
            </span>
        </div>

        <div class="card-body p-4">
            @if (!Model.Any())
            {
                <div class="alert alert-warning text-center py-5 shadow-sm rounded border-start border-warning border-4" role="alert">
                    <i class="fas fa-exclamation-triangle display-4 text-warning mb-3"></i>
                    <h4 class="fw-bold">Walay sulod ang database, brod!</h4>
                    <p class="fs-5 text-muted mb-0">Gamita ang "Add New Product" button sa ibabaw para mapun-an kini.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle border-light" style="font-size: 1.1rem;">
                        <thead class="table-light border-bottom border-2 text-secondary text-uppercase fs-6">
                            <tr>
                                <th scope="col" class="py-3" style="width: 120px;">Image</th>
                                <th scope="col" class="py-3">Product ID</th>
                                <th scope="col" class="py-3" style="width: 30%;">Product Name</th>
                                <th scope="col" class="py-3">Price</th>
                                <th scope="col" class="py-3">Stock Available</th>
                                <th scope="col" class="py-3">Items Sold</th>
                                <th scope="col" class="py-3">Date Created</th>
                                <th scope="col" class="py-3 text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                string encodedName = HttpUtility.JavaScriptStringEncode(item.Name);
                                string encodedDesc = HttpUtility.JavaScriptStringEncode(item.Description ?? "Walay deskripsyon kining produktoha.");
                                string encodedImgUrl = HttpUtility.JavaScriptStringEncode(item.ImageUrl ?? "");

                                bool hasVariants = item.ProductVariants != null && item.ProductVariants.Any();
                                string displayPrice = "";
                                int displayStock = 0;
                                string variantsJson = "[]";

                                if (hasVariants)
                                {
                                    var minPrice = item.ProductVariants.Min(v => v.Price);
                                    var maxPrice = item.ProductVariants.Max(v => v.Price);
                                    displayPrice = minPrice == maxPrice ? $"₱{minPrice:N2}" : $"₱{minPrice:N2} - ₱{maxPrice:N2}";
                                    displayStock = item.ProductVariants.Sum(v => v.Stock);

                                    var variantData = item.ProductVariants.Select(v => new
                                    {
                                        v.VariantId,
                                        v.SKU,
                                        v.VariationName,
                                        v.Price,
                                        v.Stock,
                                        ImageUrl = v.ImageUrl ?? item.ImageUrl
                                    });
                                    // Pamaagi aron luwas ang JSON sa HTML Attribute gamit ang Base64 Encoding
                                    var jsonBytes = System.Text.Encoding.UTF8.GetBytes(System.Text.Json.JsonSerializer.Serialize(variantData));
                                    variantsJson = Convert.ToBase64String(jsonBytes);
                                }
                                else
                                {
                                    displayPrice = $"₱{item.Price:N2}";
                                    displayStock = item.Stock;
                                }

                                <tr class="border-bottom border-light">
                                    <td class="py-3">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.Name"
                                                 style="width: 90px; height: 90px; object-fit: cover;"
                                                 class="rounded-3 border shadow-sm img-thumbnail" />
                                        }
                                        else
                                        {
                                            <div class="bg-light rounded-3 border d-flex align-items-center justify-content-center shadow-sm"
                                                 style="width: 90px; height: 90px;">
                                                <i class="fas fa-image text-muted display-6"></i>
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border fs-6 px-3 py-2 font-monospace">
                                            #@item.ProductId
                                        </span>
                                    </td>
                                    <td>
                                        <div class="fw-bold text-dark fs-5 mb-1">@item.Name</div>
                                        @if (hasVariants)
                                        {
                                            <span class="badge bg-info text-dark font-monospace"><i class="fas fa-tags me-1"></i> @item.ProductVariants.Count Variations</span>
                                        }
                                        else
                                        {
                                            <small class="text-muted">Standard Product</small>
                                        }
                                    </td>
                                    <td>
                                        <span class="text-success fw-bold @(hasVariants ? "fs-5" : "fs-4")">
                                            @displayPrice
                                        </span>
                                    </td>
                                    <td>
                                        @if (displayStock > 0)
                                        {
                                            <span class="badge bg-success-subtle text-success fs-6 border border-success-subtle px-3 py-2 rounded-3 fw-bold">
                                                <i class="fas fa-box me-1"></i> @displayStock pcs
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger fs-6 border border-danger-subtle px-3 py-2 rounded-3 fw-bold">
                                                <i class="fas fa-times-circle me-1"></i> Out of Stock
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <div class="fw-semibold text-secondary fs-5 ps-2">
                                            <i class="fas fa-shopping-basket text-muted me-1 fs-6"></i> @item.SoldCount
                                        </div>
                                    </td>
                                    <td>
                                        <div class="text-dark fs-6 fw-medium">
                                            @item.CreatedAt.ToString("MMMM dd, yyyy")
                                        </div>
                                        <small class="text-muted font-monospace">@item.CreatedAt.ToString("hh:mm tt")</small>
                                    </td>
                                    <td class="text-center">
                                        @if (hasVariants)
                                        {
                                            <button type="button"
                                                    class="btn btn-outline-info btn-md px-3 fw-bold shadow-sm open-modal-btn"
                                                    data-id="@item.ProductId"
                                                    data-name="@encodedName"
                                                    data-price="@item.Price"
                                                    data-stock="@item.Stock"
                                                    data-desc="@encodedDesc"
                                                    data-imgurl="@encodedImgUrl"
                                                    data-variants="@variantsJson">
                                                <i class="fas fa-tasks me-1"></i> Manage Variations
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button"
                                                    class="btn btn-outline-dark btn-md px-3 fw-bold shadow-sm open-modal-btn"
                                                    data-id="@item.ProductId"
                                                    data-name="@encodedName"
                                                    data-price="@item.Price"
                                                    data-stock="@item.Stock"
                                                    data-desc="@encodedDesc"
                                                    data-imgurl="@encodedImgUrl"
                                                    data-variants="">
                                                <i class="fas fa-eye me-1"></i> View / Edit
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="productQuickViewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <form asp-action="UpdateProduct" asp-controller="Admin" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header bg-dark text-white py-3">
                    <h5 class="modal-title fs-5 fw-bold" id="modalHeaderTitle">
                        <i class="fas fa-box-open text-warning me-2"></i> Product Quick View
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body p-4">
                    <input type="hidden" id="modalProductId" name="ProductId" />

                    <div class="row g-4">
                        <div class="col-md-5 text-center border-end border-light d-flex flex-column align-items-center justify-content-center bg-light rounded p-3">
                            <img id="modalProductImage" src="" alt="Product Image"
                                 class="img-fluid rounded-3 shadow border bg-white mb-2"
                                 style="max-height: 280px; object-fit: contain; width: 100%; display: none;" />
                            <div id="modalNoImagePlaceholder" class="text-muted my-5" style="display: none;">
                                <i class="fas fa-image display-1 text-black-50 mb-2"></i>
                                <p class="mb-0 fw-medium">No Image Available</p>
                            </div>
                            <span class="badge bg-secondary fs-6 px-3 py-2 font-monospace mt-2" id="modalProductIdBadge"></span>
                        </div>

                        <div class="col-md-7">
                            <div class="mb-3">
                                <label class="form-label fw-bold text-secondary">Product Name</label>
                                <input type="text" id="modalProductName" name="Name" class="form-control form-control-lg fw-bold text-dark border-2" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold text-secondary">Description</label>
                                <textarea id="modalProductDescription" name="Description" class="form-control border-2" rows="3" placeholder="Isulat ang detalye sa produkto dinhi..."></textarea>
                            </div>

                            <div class="row" id="basePriceStockSection">
                                <div class="col-6 mb-3">
                                    <label class="form-label fw-bold text-success">Base Price (₱)</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-success text-white border-success fw-bold">₱</span>
                                        <input type="number" id="modalProductPrice" name="Price" class="form-control form-control-lg fw-bold border-2 border-start-0 text-success" step="0.01" />
                                    </div>
                                </div>

                                <div class="col-6 mb-3">
                                    <label class="form-label fw-bold text-warning">Base Stock Qty</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-warning text-dark border-warning fw-bold"><i class="fas fa-boxes"></i></span>
                                        <input type="number" id="modalProductStock" name="Stock" class="form-control form-control-lg fw-bold border-2 border-start-0 text-dark" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-4 d-none" id="modalVariantsSection">
                        <div class="col-12">
                            <div class="border-top pt-3">
                                <h5 class="fw-bold text-dark mb-3"><i class="fas fa-tags text-info me-2"></i>Product Variations List</h5>
                                <p class="text-muted small">Kini nga produkto naay variations. Ang matag variation naay kaugalingong presyo, stock, ug SKU. Palihug i-update sa ubos.</p>

                                <div class="table-responsive bg-white border rounded shadow-sm">
                                    <table class="table table-sm align-middle mb-0">
                                        <thead class="table-light text-secondary text-uppercase font-monospace small">
                                            <tr>
                                                <th scope="col" style="width: 70px;" class="ps-3">Img</th>
                                                <th scope="col">Variation Name</th>
                                                <th scope="col">SKU Code</th>
                                                <th scope="col" style="width: 160px;">Price (₱)</th>
                                                <th scope="col" style="width: 130px;">Stock</th>
                                            </tr>
                                        </thead>
                                        <tbody id="variantsTableBody">
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer bg-light py-3">
                    <button type="button" class="btn btn-secondary btn-lg px-4" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-success btn-lg px-4 shadow-sm">
                        <i class="fas fa-save me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var modalButtons = document.querySelectorAll('.open-modal-btn');

        modalButtons.forEach(function (button) {
            button.addEventListener('click', function () {
                var id = this.getAttribute('data-id');
                var name = this.getAttribute('data-name');
                var price = this.getAttribute('data-price');
                var stock = this.getAttribute('data-stock');
                var description = this.getAttribute('data-desc');
                var imageUrl = this.getAttribute('data-imgurl');
                var base64Variants = this.getAttribute('data-variants');

                openQuickViewModal(id, name, price, stock, description, imageUrl, base64Variants);
            });
        });
    });

    function openQuickViewModal(id, name, price, stock, description, imageUrl, base64Variants) {
        document.getElementById('modalProductId').value = id;
        document.getElementById('modalProductName').value = name;
        document.getElementById('modalProductDescription').value = description;
        document.getElementById('modalProductIdBadge').innerText = "PRODUCT ID: #" + id;

        var imgElement = document.getElementById('modalProductImage');
        var placeholderElement = document.getElementById('modalNoImagePlaceholder');
        if (imageUrl && imageUrl.trim() !== "") {
            imgElement.src = imageUrl;
            imgElement.style.display = "block";
            placeholderElement.style.display = "none";
        } else {
            imgElement.src = "";
            imgElement.style.display = "none";
            placeholderElement.style.display = "block";
        }

        var baseSection = document.getElementById('basePriceStockSection');
        var variantsSection = document.getElementById('modalVariantsSection');
        var tableBody = document.getElementById('variantsTableBody');

        tableBody.innerHTML = "";
        var variants = [];

        // Luwas nga pag-decode sa Base64 string pabalik ngadto sa JSON Object
        if (base64Variants && base64Variants.trim() !== "") {
            try {
                var jsonString = atob(base64Variants);
                variants = JSON.parse(jsonString);
            } catch (e) {
                console.error("Error decoding or parsing variants JSON:", e);
            }
        }

        if (variants && variants.length > 0) {
            baseSection.style.display = "none";
            document.getElementById('modalProductPrice').removeAttribute('required');
            document.getElementById('modalProductStock').removeAttribute('required');
            variantsSection.classList.remove('d-none');

            variants.forEach(function(variant, index) {
                var row = document.createElement('tr');
                row.innerHTML = `
                    <td class="ps-3 py-2">
                        <img src="${variant.ImageUrl || imageUrl || '/images/no-image.png'}"
                             style="width: 45px; height: 45px; object-fit: cover;" class="rounded border shadow-sm" />
                    </td>
                    <td>
                        <input type="hidden" name="ProductVariants[${index}].VariantId" value="${variant.VariantId}" />
                        <span class="fw-bold text-dark fs-6">${variant.VariationName}</span>
                    </td>
                    <td>
                        <input type="text" name="ProductVariants[${index}].SKU" class="form-control form-control-sm font-monospace bg-light" value="${variant.SKU}" readonly />
                    </td>
                    <td>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-success-subtle text-success fw-bold">₱</span>
                            <input type="number" name="ProductVariants[${index}].Price" class="form-control form-control-sm fw-bold text-success border-2" step="0.01" value="${variant.Price}" required />
                        </div>
                    </td>
                    <td>
                        <input type="number" name="ProductVariants[${index}].Stock" class="form-control form-control-sm fw-bold text-dark border-2" value="${variant.Stock}" required />
                    </td>
                `;
                tableBody.appendChild(row);
            });
        }
        else {
            baseSection.style.display = "flex";
            document.getElementById('modalProductPrice').setAttribute('required', 'required');
            document.getElementById('modalProductStock').setAttribute('required', 'required');

            document.getElementById('modalProductPrice').value = price;
            document.getElementById('modalProductStock').value = stock;
            variantsSection.classList.add('d-none');
        }

        var modalEl = document.getElementById('productQuickViewModal');
        var myModal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
        myModal.show();
    }
</script>