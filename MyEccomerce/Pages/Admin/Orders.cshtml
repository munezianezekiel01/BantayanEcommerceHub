@model List<MyEccomerce.Models.Order>
@inject MyEccomerce.Data.ApplicationDbContext _context
@{
    var user = ViewBag.CurrentUser as MyEccomerce.Models.User;
    var currentUser = _context.Users.FirstOrDefault(u => u.UserId == 1);
    Layout = "_AdminLayout";
}

<div class="container mt-5 mb-5">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold"><i class="bi bi-shop shadow-sm p-2 rounded bg-primary text-white"></i> Shop Owner Dashboard</h4>
        <span class="badge bg-danger rounded-pill px-3 py-2" id="pendingCounter">
            @Model.Count(x => x.Status == "Pending") Bag-ong Order
        </span>
    </div>

    <!-- FEATURE 1: Search ug Filter Tabs -->
    <div class="card shadow-sm border-0 mb-4 p-3 bg-white">
        <div class="row g-2 align-items-center">
            <div class="col-md-4">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                    <input type="text" id="orderSearch" class="form-control border-start-0 bg-light" placeholder="Pangitaa ang Customer o Order ID...">
                </div>
            </div>
            <div class="col-md-8 text-md-end">
                <!-- Filter Buttons (Dali ra i-filter gamit ang JS sa ubos) -->
                <button class="btn btn-sm btn-outline-secondary active filter-btn" onclick="filterOrders('All')">Tanan</button>
                <button class="btn btn-sm btn-outline-warning text-dark filter-btn" onclick="filterOrders('Pending')">Pending</button>
                <button class="btn btn-sm btn-outline-primary filter-btn" onclick="filterOrders('Confirmed')">Confirmed</button>
                <button class="btn btn-sm btn-outline-info filter-btn" onclick="filterOrders('Out for Delivery')">On the Way</button>
                <button class="btn btn-sm btn-outline-success filter-btn" onclick="filterOrders('Completed')">Completed</button>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center p-5 border rounded bg-light">
            <h5 class="text-muted">Walay order pa karon, @currentUser?.FirstName </h5>
        </div>
    }

    <!-- Orders Loop -->
    <div id="ordersContainer">
        @foreach (var order in Model)
        {
            // GI-AYO: Gi-adjust ang badge class base sa tinuod nga status string sa imong switch case
            var badgeClass = order.Status == "Pending" ? "bg-warning text-dark" :
            order.Status == "Completed" ? "bg-success" :
            order.Status == "Cancelled" ? "bg-secondary" :
            order.Status == "Out for Delivery" ? "bg-info text-dark" : "bg-primary";

            <!-- Gidugangan og data attributes para sa sayon nga pag-filter ug search sa JS -->
            <div class="card order-card shadow-sm border-0 mb-4 overflow-hidden"
                 data-status="@order.Status"
                 data-customer="@(order.User?.FirstName) @(order.User?.LastName)"
                 data-id="#@order.OrderId">

                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3 border-bottom">
                    <div>
                        <span class="text-muted small">ORDER ID:</span> <span class="fw-bold">#@order.OrderId</span>
                        <span class="ms-3 text-muted small">DATE:</span> <span class="small">@order.OrderDate.ToString("MMM dd, yyyy hh:mm tt")</span>
                    </div>
                    <span class="badge @badgeClass px-3">@order.Status</span>
                </div>

                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 border-end">
                            <h6 class="text-secondary fw-bold small text-uppercase mb-3">Delivery To:</h6>
                            <p class="mb-1 fw-bold">@(order.User?.FirstName) @(order.User?.LastName)</p>
                            <p class="text-muted small mb-2"><i class="bi bi-geo-alt-fill text-danger"></i> @order.DeliveryAddress</p>
                            <p class="small fw-bold text-primary"><i class="bi bi-telephone"></i> @(order.User?.Phone ?? "No Phone")</p>
                        </div>

                        <div class="col-md-5 border-end">
                            <h6 class="text-secondary fw-bold small text-uppercase mb-3">Items Ordered:</h6>
                            @foreach (var item in order.OrderItems)
                            {
                                <div class="d-flex align-items-center mb-3">
                                    <img src="@(item.Variant != null && !string.IsNullOrEmpty(item.Variant.ImageUrl) ? item.Variant.ImageUrl : item.Product?.ImageUrl)"
                                         width="45" height="45" class="me-3 rounded border shadow-sm">

                                    <div style="font-size: 0.9rem;">
                                        <div class="fw-bold text-dark">@item.Product?.Name</div>
                                        @if (item.Variant != null)
                                        {
                                            <div class="text-primary small fw-bold">
                                                Variation: <span class="text-secondary">@item.Variant.VariationName</span>
                                            </div>
                                        }
                                        <div class="text-muted small">₱@item.Price.ToString("N2") x @item.Quantity</div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="col-md-3 text-end">
                            <h6 class="text-secondary fw-bold small text-uppercase mb-3">Total Payment:</h6>
                            <h3 class="fw-bold text-danger">₱@order.TotalAmount.ToString("N2")</h3>
                            <p class="badge bg-light text-dark border small mt-1">Cash on Delivery</p>

                            <div class="d-grid gap-2 mt-2">
                                @switch (order.Status)
                                {
                                    case "Pending":
                                        <button class="btn btn-primary btn-sm" onclick="updateStatus(@order.OrderId, 'Confirmed')">
                                            <i class="bi bi-check-circle"></i> Accept Order
                                        </button>
                                        break;

                                    case "Confirmed":
                                        <button class="btn btn-warning btn-sm text-dark" onclick="updateStatus(@order.OrderId, 'Out for Delivery')">
                                            <i class="bi bi-bicycle"></i> Out for Delivery
                                        </button>
                                        break;

                                    case "Out for Delivery":
                                        <button class="btn btn-success btn-sm" onclick="updateStatus(@order.OrderId, 'Completed')">
                                            <i class="bi bi-check2-all"></i> Mark Completed
                                        </button>
                                        break;

                                    case "Completed":
                                        <span class="badge bg-success p-2"><i class="bi bi-hand-thumbs-up"></i> Order Success</span>
                                        break;

                                    case "Cancelled":
                                        <span class="badge bg-secondary p-2"><i class="bi bi-x-circle"></i> Order Cancelled</span>
                                        break;
                                }

                                <!-- FEATURE 3: Print Receipt Element (Mao ni idugang) -->
                                <button class="btn btn-outline-secondary btn-sm" onclick="window.print()">
                                    <i class="bi bi-printer"></i> Print Invoice
                                </button>

                                @if (order.Status == "Pending")
                                {
                                    <button class="btn btn-link btn-sm text-decoration-none text-muted mt-1" onclick="updateStatus(@order.OrderId, 'Cancelled')">
                                        Cancel Order
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>


<script>
    // FEATURE 1: Client-side Search ug Filter Logic (Wala nay sige refresh)
    function filterOrders(status) {
        $('.filter-btn').removeClass('active');
        $(event.target).addClass('active');

        $('.order-card').each(function() {
            var cardStatus = $(this).data('status');
            if(status === 'All' || cardStatus === status) {
                $(this).show();
            } else {
                $(this).hide();
            }
        });
    }

    $('#orderSearch').on('keyup', function() {
        var value = $(this).val().toLowerCase();
        $('.order-card').each(function() {
            var name = $(this).data('customer').toLowerCase();
            var id = $(this).data('id').toLowerCase();
            if(name.indexOf(value) > -1 || id.indexOf(value) > -1) {
                $(this).show();
            } else {
                $(this).hide();
            }
        });
    });

    // Original Update Status Function
    function updateStatus(id, newStatus) {
        Swal.fire({
            title: 'Sigurado ka, boss?',
            text: "I-update nato ang order mahimong: " + newStatus,
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#0d6efd',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Oo, Dayon!'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '/Admin/UpdateStatus',
                    type: 'POST',
                    data: { orderId: id, status: newStatus },
                    success: function (res) {
                        if (res.success) {
                            location.reload();
                        } else {
                            Swal.fire('Error', 'Naay sayop sa pag-save, boss.', 'error');
                        }
                    }
                });
            }
        });
    }

    
</script>