@model MyEccomerce.Models.Order

@{
    ViewData["Title"] = "Track Order #" + Model.OrderId;
}

<div class="container mt-4">
    <div class="card shadow-sm border-0" style="border-radius: 20px; overflow: hidden;">
        <div class="card-header bg-primary text-white p-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-geo-alt-fill"></i> Tracking Order #@Model.OrderId</h5>
            <small>Status: <span id="statusText">@Model.Status</span></small>
        </div>

        <div id="map" style="height: 450px; width: 100%;"></div>

        <div class="card-footer bg-white p-4">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h6 class="text-muted small text-uppercase fw-bold">Delivery Address</h6>
                    <p class="mb-0">@Model.DeliveryAddress</p>
                </div>
                <div class="col-md-6 text-md-end mt-3 mt-md-0">
                    <div id="connectionStatus" class="badge bg-secondary-subtle text-secondary border">
                        Connecting to rider...
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

    <script>
        // 1. Initialize Map (Center sa Santa Fe/Bantayan or default coordinates)
        var map = L.map('map').setView([11.1537, 123.8054], 16);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        // Custom Icon para sa Rider (Motorcycle)
        var riderIcon = L.icon({
            iconUrl: 'https://cdn-icons-png.flaticon.com/512/713/713422.png', // Pwede nimo ilisan og local image
            iconSize: [40, 40],
            iconAnchor: [20, 20]
        });

        var riderMarker = L.marker([11.1537, 123.8054], { icon: riderIcon }).addTo(map)
            .bindPopup("<b>B-HUB Rider</b><br>Padulong na ko, Boss!").openPopup();

        // 2. SignalR Connection Setup
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/trackingHub")
            .withAutomaticReconnect()
            .build();

        const orderId = "@Model.OrderId";

        // Listen sa location updates gikan sa Hub
        connection.on("ReceiveLocation", function (lat, lng) {
            console.log("New location received:", lat, lng);

            var newPos = new L.LatLng(lat, lng);
            riderMarker.setLatLng(newPos);
            map.panTo(newPos); // I-follow ang rider sa mapa

            // Update Status UI
            document.getElementById("connectionStatus").className = "badge bg-success-subtle text-success border";
            document.getElementById("connectionStatus").innerHTML = "<i class='bi bi-record-fill animate-pulse'></i> Live Tracking Active";
        });

        // Start Connection
        connection.start().then(function () {
            console.log("Connected to SignalR Hub");
            connection.invoke("JoinOrderGroup", orderId);

            document.getElementById("connectionStatus").innerHTML = "Waiting for rider location...";
        }).catch(function (err) {
            return console.error(err.toString());
        });
    </script>

    <style>
        /* Pulse effect para sa Live indicator */
        .animate-pulse {
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        @@keyframes pulse {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: .5;
            }
        }

        #map {
            z-index: 1;
        }
    </style>
}