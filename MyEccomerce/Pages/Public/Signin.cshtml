@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - MyEcommerce</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body {
            background: #f0f2f5;
            display: flex;
            align-items: center;
            height: 100vh;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            background: white;
        }

        .btn-primary-blue {
            background-color: #1877f2;
            border: none;
            color: white;
            font-weight: 600;
            transition: 0.3s;
        }

            .btn-primary-blue:hover {
                background-color: #166fe5;
                transform: translateY(-2px);
                color: white;
            }

        /* --- KINI ANG GI-ADD PARA SA FACEBOOK --- */
        .btn-facebook {
            background-color: #1877f2;
            border: none;
            color: white;
            font-weight: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: 0.3s;
            margin-bottom: 12px;
        }

            .btn-facebook:hover {
                background-color: #166fe5;
                box-shadow: 0 4px 12px rgba(24, 119, 242, 0.3);
                color: white;
                transform: translateY(-1px);
            }

            .btn-facebook i {
                margin-right: 10px;
                font-size: 1.2rem;
            }
        /* -------------------------------------- */

        .btn-google {
            background-color: white;
            border: 1px solid #dadce0;
            color: #3c4043;
            font-weight: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: 0.3s;
        }

            .btn-google:hover {
                background-color: #f8f9fa;
                border-color: #d2e3fc;
                box-shadow: 0 1px 3px rgba(60,64,67, 0.3);
                color: #202124;
            }

            .btn-google i {
                color: #4285F4;
                margin-right: 10px;
                font-size: 1.2rem;
            }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 25px 0;
            color: #8d949e;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                border-bottom: 1px solid #ced4da;
            }

            .divider:not(:empty)::before {
                margin-right: .5em;
            }

            .divider:not(:empty)::after {
                margin-left: .5em;
            }

        .form-control {
            border-radius: 8px;
            padding: 12px;
            background-color: #f5f6f7;
            border: 1px solid #dddfe2;
        }

            .form-control:focus {
                background-color: #fff;
                border-color: #1877f2;
                box-shadow: none;
            }

        h3 {
            font-weight: 700;
            color: #1c1e21;
        }
    </style>
</head>
<body>

    <div class="login-card shadow-lg">
        <div class="text-center mb-4">
            <h3>Welcome Back</h3>
            <p class="text-muted small">Pag-sign in aron makasugod sa shopping.</p>
        </div>

        <form asp-controller="Account" asp-action="Login" method="post">
            <div class="mb-3">
                <input type="email" class="form-control" name="Email" placeholder="Email Address" required />
            </div>
            <div class="mb-3">
                <input type="password" class="form-control" name="Password" placeholder="Password" required />
            </div>
            <button type="submit" class="btn btn-primary-blue w-100 py-2 mb-2 shadow-sm">
                Login
            </button>
            <div class="text-center">
                <a href="#" class="text-decoration-none small text-primary">Forgot Password?</a>
            </div>
        </form>

        <div class="divider small">or login with</div>

        <a asp-controller="Account" asp-action="FacebookLogin" class="btn btn-facebook w-100 py-2 shadow-sm">
            <i class="fab fa-facebook"></i> Sign in with Facebook
        </a>

        <a asp-controller="Account" asp-action="GoogleLogin" class="btn btn-google w-100 py-2 shadow-sm">
            <i class="fab fa-google"></i> Sign in with Google
        </a>

        <div class="mt-4 text-center">
            <p class="small text-muted">Wala pa'y account? <a href="#" class="text-primary text-decoration-none fw-bold">Sign Up</a></p>
            <a href="/" class="text-decoration-none text-secondary small">
                <i class="fas fa-arrow-left me-1"></i> Back to Home
            </a>
        </div>
    </div>

</body>
</html>