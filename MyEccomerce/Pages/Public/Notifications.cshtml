<div class="container py-3 py-md-5">
    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-7 col-md-9 col-12">

            <div class="d-flex justify-content-between align-items-center mb-3 mb-md-4 pb-2 border-bottom">
                <h5 class="fw-bold m-0 text-dark d-flex align-items-center responsive-header">
                    <i class="bi bi-bell text-primary me-2 fs-4"></i> Notifications
                </h5>
                <div id="unread-badge-container">
                </div>
            </div>

            <div id="notification-full-list" class="list-group rounded-3 overflow-hidden border shadow-sm">
                <div class="text-center py-5 bg-white" id="notif-loader">
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                    <p class="mt-2 text-muted responsive-meta mb-0">Gikuha pa ang imong mga updates...</p>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    /* Responsive Text Typography gamit ang CSS Clamp */
    .responsive-header {
        font-size: clamp(1.1rem, 2vw + 0.8rem, 1.35rem) !important;
    }

    .notif-title {
        font-size: clamp(0.85rem, 1vw + 0.7rem, 0.95rem) !important;
        line-height: 1.35;
    }

    .responsive-meta {
        font-size: clamp(0.7rem, 0.8vw + 0.6rem, 0.8rem) !important;
    }

    .notif-status-badge {
        font-size: clamp(0.6rem, 0.5vw + 0.55rem, 0.7rem) !important;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 3px 8px;
        border-radius: 4px;
        display: inline-block;
    }

    /* Container global background constraint */
    #notification-full-list {
        background-color: #ffffff;
    }

    /* Card Layout structure and interactions */
    .notif-item {
        transition: background-color 0.15s ease;
        border: none !important;
        border-bottom: 1px solid #f1f3f5 !important;
        display: block;
        background-color: #ffffff;
        text-decoration: none !important;
    }

        .notif-item:last-child {
            border-bottom: none !important;
        }

        .notif-item:hover {
            background-color: #f8f9fa !important;
        }

    /* Focus styling for Unread notifications */
    .notif-unread {
        background-color: #f4f8ff !important;
        position: relative;
    }

        /* Elegant unread side-bar indicator */
        .notif-unread::before {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            background-color: #0d6efd;
        }

    /* Collage Layout Core (Flexible Thumbnail Wrapper) */
    .notif-collage-wrapper {
        display: grid;
        width: clamp(48px, 5vw + 40px, 58px);
        height: clamp(48px, 5vw + 40px, 58px);
        gap: 2px;
        flex-shrink: 0;
        border-radius: 8px;
        overflow: hidden;
        background: #f1f3f5;
    }

    /* Image layouts depending on count */
    .grid-1-item {
        grid-template-columns: 1fr;
    }

    .grid-2-items {
        grid-template-columns: repeat(2, 1fr);
    }

    .grid-3-items {
        grid-template-columns: repeat(2, 1fr);
    }

        .grid-3-items .notif-img:first-child {
            grid-row: span 2;
        }

    .grid-4-items {
        grid-template-columns: repeat(2, 1fr);
    }

    .notif-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* Semantic Dynamic Status Colors */
    .status-pending {
        background-color: #fff3cd;
        color: #856404;
        border: 1px solid #ffeeba;
    }

    .status-delivered {
        background-color: #d1e7dd;
        color: #0f5132;
    }

    .status-shipped {
        background-color: #cff4fc;
        color: #055160;
    }

    .status-default {
        background-color: #e2e3e5;
        color: #41464b;
    }

   
</style>

<script src="~/js/PagesScript/OrdersStatusNotification.js"></script>