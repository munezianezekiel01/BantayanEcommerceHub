@model MyEccomerce.Models.User

@* ========================================== *@
@* INLINE CUSTOM STYLE: IMONG COLOR PALETTE  *@
@* ========================================== *@
<style>
    :root {
        --king-blue: #0047AB; /* Kang Marie: Elegant, Deep, Devoted */
        --dev-green: #2E7D32; /* Kanimo, Boss: Growth, Hard Work, Dedicated */
        --bhub-cyan: #00E5FF; /* Kombinasyon: Modern Tech Vibe, Radiant Glow */
    }

    /* Pag-override sa Active Tab Button para mosiga ang Kombinasyon (Cyan) uban ang King Blue background */
    .nav-pills .nav-link.active {
        background-color: var(--king-blue) !important;
        color: #ffffff !important;
        border-left: 5px solid var(--bhub-cyan) !important;
        box-shadow: 0 4px 12px rgba(0, 71, 171, 0.2);
    }

    /* Hover State sa mga Tab Links */
    .nav-link:not(.active):hover {
        color: var(--king-blue) !important;
        background-color: rgba(0, 71, 171, 0.05) !important;
    }

    /* Link and Custom Badge Accent Color */
    .text-marie {
        color: var(--king-blue) !important;
    }

    .text-ian {
        color: var(--dev-green) !important;
    }

    .bg-cyan-glow {
        background-color: var(--bhub-cyan) !important;
        color: #121212 !important;
    }

    /* Global Primary Button Color adjustments sa B-Hub */
    .btn-bhub-primary {
        background-color: var(--king-blue) !important;
        color: #ffffff !important;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-bhub-primary:hover {
            background-color: #003380 !important;
            box-shadow: 0 0 10px rgba(0, 229, 255, 0.5);
        }
</style>

<div class="container py-5">
    @if (Model != null)
    {
        <div class="row g-4">

            @* ========================================== *@
            @* SIDEBAR: PROFILE SUMMARY & NAVIGATION      *@
            @* ========================================== *@
            <div class="col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm mb-4" style="border-radius: 8px; border-top: 4px solid var(--king-blue) !important;">
                    <div class="card-body text-center p-4">
                        <img src="@(!string.IsNullOrEmpty(Model.ImageUrl) ? Model.ImageUrl : "https://ui-avatars.com/api/?name=" + Model.FirstName + "&background=0047AB&color=fff&size=128")"
                             class="rounded-circle border mb-3"
                             style="width: 90px; height: 90px; object-fit: cover; border-color: var(--king-blue) !important; border-width: 2px !important;"
                             alt="Profile Picture">

                        <h5 class="fw-bold mb-1" style="color: #212529;">@Model.FirstName @Model.LastName</h5>

                        @* Green badge para sa imong personal status (Active Dev Growth) *@
                        <span class="badge fw-semibold rounded-pill px-3 py-1" style="font-size: 0.65rem; background-color: rgba(46, 125, 50, 0.15) !important; color: var(--dev-green) !important;">
                            <i class="bi bi-patch-check-fill me-1"></i> Active Member
                        </span>
                    </div>
                </div>

                @* VERTICAL TABS CONTROLLER *@
                <div class="nav flex-column nav-pills shadow-sm p-2 bg-white" id="v-pills-tab" role="tablist" aria-orientation="vertical" style="border-radius: 8px;">
                    <button class="nav-link active text-start py-3" id="v-pills-profile-tab" data-bs-toggle="pill" data-bs-target="#v-pills-profile" type="button" role="tab">
                        <i class="bi bi-person-circle me-2"></i> Personal Info
                    </button>
                    <button class="nav-link text-start py-3" id="v-pills-orders-tab" data-bs-toggle="pill" data-bs-target="#v-pills-orders" type="button" role="tab">
                        <i class="bi bi-receipt me-2"></i> Order History
                    </button>
                    <button class="nav-link text-start py-3" id="v-pills-transactions-tab" data-bs-toggle="pill" data-bs-target="#v-pills-transactions" type="button" role="tab">
                        <i class="bi bi-credit-card me-2"></i> Transactions & Billing
                    </button>
                    <button class="nav-link text-start py-3" id="v-pills-reviews-tab" data-bs-toggle="pill" data-bs-target="#v-pills-reviews" type="button" role="tab">
                        <i class="bi bi-star me-2"></i> My Reviews
                    </button>
                    <button class="nav-link text-start py-3" id="v-pills-settings-tab" data-bs-toggle="pill" data-bs-target="#v-pills-settings" type="button" role="tab">
                        <i class="bi bi-gear me-2"></i> Account Settings
                    </button>
                </div>
            </div>

            @* ========================================== *@
            @* MAIN CONTENT AREA: DISPLAY PER TAB STATUS  *@
            @* ========================================== *@
            <div class="col-md-8 col-lg-9">
                <div class="tab-content" id="v-pills-tabContent">

                    @* -------------------------------------- *@
                    @* TAB 1: PERSONAL INFO                   *@
                    @* -------------------------------------- *@
                    <div class="tab-pane fade show active" id="v-pills-profile" role="tabpanel" aria-labelledby="v-pills-profile-tab">
                        <div class="card border-0 shadow-sm" style="border-radius: 8px; background-color: #ffffff;">

                            <div class="card-body p-4 border-bottom">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <h4 class="fw-bold mb-1" style="color: #212529;">Personal Information</h4>
                                        <p class="text-muted small mb-0">Imong pribadong detalye ug kasayuran sa account.</p>
                                    </div>
                                    <a href="/Account/EditProfile" class="btn btn-outline-primary btn-sm px-3 rounded-pill fw-semibold" style="font-size: 0.8rem; border-color: var(--king-blue); color: var(--king-blue);">
                                        <i class="bi bi-pencil-square me-1"></i> Edit Profile
                                    </a>
                                </div>
                            </div>

                            <div class="card-body p-4">
                                <div class="row g-4">

                                    <div class="col-sm-6">
                                        <label class="text-muted small fw-bold text-uppercase mb-1" style="letter-spacing: 0.5px; font-size: 0.7rem;">First Name</label>
                                        <div class="p-3 bg-light rounded border-0 text-dark fw-medium d-flex align-items-center gap-2">
                                            <i class="bi bi-person text-secondary"></i>
                                            @Model.FirstName
                                        </div>
                                    </div>

                                    <div class="col-sm-6">
                                        <label class="text-muted small fw-bold text-uppercase mb-1" style="letter-spacing: 0.5px; font-size: 0.7rem;">Last Name</label>
                                        <div class="p-3 bg-light rounded border-0 text-dark fw-medium d-flex align-items-center gap-2">
                                            <i class="bi bi-person text-secondary"></i>
                                            @Model.LastName
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <label class="text-muted small fw-bold text-uppercase mb-1" style="letter-spacing: 0.5px; font-size: 0.7rem;">Email Address</label>
                                        <div class="p-3 bg-light rounded border-0 text-dark fw-medium d-flex align-items-center gap-2">
                                            <i class="bi bi-envelope text-marie"></i>
                                            @Model.Email
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <label class="text-muted small fw-bold text-uppercase mb-1" style="letter-spacing: 0.5px; font-size: 0.7rem;">Phone Number</label>
                                        <div class="p-3 bg-light rounded border-0 text-dark fw-medium d-flex align-items-center gap-2">
                                            <i class="bi bi-phone text-marie"></i>
                                            @(!string.IsNullOrEmpty(Model.Phone) ? Model.Phone : "Wala pa nabutangan, Boss.")
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <label class="text-muted small fw-bold text-uppercase mb-1" style="letter-spacing: 0.5px; font-size: 0.7rem;">Default Delivery Address</label>
                                        <div class="p-3 bg-light rounded border-0 text-dark fw-medium d-flex align-items-start gap-2">
                                            <i class="bi bi-geo-alt text-marie mt-1"></i>
                                            <span>@(!string.IsNullOrEmpty(Model.Address) ? Model.Address : "Wala pa kay default address nga gi-save, Boss.")</span>
                                        </div>
                                    </div>

                                    <div class="col-12 border-top pt-3 mt-4">
                                        <p class="small text-muted mb-0 d-flex align-items-center gap-2" style="font-size: 0.75rem;">
                                            <i class="bi bi-calendar-check text-ian"></i>
                                            <span>Kini nga account opisyal nga namugna niadtong <strong>@Model.DateCreated.ToString("MMMM dd, yyyy")</strong></span>
                                        </p>
                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>

                    @* -------------------------------------- *@
                    @* TAB 2: ORDER HISTORY (DYNAMIC NA CORNER) *@
                    @* -------------------------------------- *@
                    <div class="tab-pane fade" id="v-pills-orders" role="tabpanel" aria-labelledby="v-pills-orders-tab">
                        <div class="card border-0 shadow-sm" style="border-radius: 8px; background-color: #ffffff;">

                            <div class="card-body p-4 border-bottom">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <h4 class="fw-bold mb-1" style="color: #212529;">My Purchase History</h4>
                                        <p class="text-muted small mb-0">Dali-a pag-monitor sa imong mga orders ug mga gipamalit sa B-Hub.</p>
                                    </div>
                                    <a href="@Url.Action("MyOrders", "Orders")" class="btn btn-bhub-primary btn-sm px-3 rounded-pill fw-semibold" style="font-size: 0.8rem;">
                                        <i class="bi bi-fullscreen me-1"></i> View Full Orders
                                    </a>
                                </div>
                            </div>

                            <div class="card-body p-4">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle" style="font-size: 0.9rem;">
                                        <thead class="table-light text-muted small fw-bold text-uppercase">
                                            <tr>
                                                <th scope="col" class="border-0 py-3">Order ID</th>
                                                <th scope="col" class="border-0 py-3">Date</th>
                                                <th scope="col" class="border-0 py-3">Total Price</th>
                                                <th scope="col" class="border-0 py-3">Status</th>
                                                <th scope="col" class="border-0 py-3 text-end">Aksyon</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td class="fw-bold text-secondary py-3">#BH-98431</td>
                                                <td class="text-muted">June 05, 2026</td>
                                                <td class="fw-semibold text-dark">₱1,450.00</td>
                                                <td>
                                                    <span class="badge bg-warning-subtle text-warning px-3 py-2 rounded-pill fw-medium" style="font-size: 0.7rem;">
                                                        <i class="bi bi-clock-history me-1"></i> Pending
                                                    </span>
                                                </td>
                                                <td class="text-end">
                                                    <button type="button" class="btn btn-light btn-sm rounded-circle" onclick="viewOrderDetails(98431)">
                                                        <i class="bi bi-eye text-marie"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="fw-bold text-secondary py-3">#BH-97210</td>
                                                <td class="text-muted">May 28, 2026</td>
                                                <td class="fw-semibold text-dark">₱3,200.00</td>
                                                <td>
                                                    <span class="badge bg-success-subtle text-ian px-3 py-2 rounded-pill fw-medium" style="font-size: 0.7rem; background-color: rgba(46, 125, 50, 0.1) !important;">
                                                        <i class="bi bi-check-circle me-1"></i> Completed
                                                    </span>
                                                </td>
                                                <td class="text-end">
                                                    <button type="button" class="btn btn-light btn-sm rounded-circle" onclick="viewOrderDetails(97210)">
                                                        <i class="bi bi-eye text-marie"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </div>

                    @* -------------------------------------- *@
                    @* TAB 3: TRANSACTIONS & BILLING          *@
                    @* -------------------------------------- *@
                    <div class="tab-pane fade" id="v-pills-transactions" role="tabpanel">
                        <div class="card border-0 shadow-sm p-4" style="border-radius: 8px;">
                            <h4 class="fw-bold mb-3" style="color: var(--king-blue);">Transactions & Payments</h4>
                            <p class="text-muted small">Listahan sa mga nadawat nga bayad ug mga e-receipts gikan sa B-Hub.</p>
                            <hr class="opacity-25">
                            <div class="alert text-dark border-0 p-3 bg-cyan-glow d-flex align-items-center gap-2" style="border-radius: 6px; font-weight: 500;">
                                <i class="bi bi-info-circle-fill"></i> Magsunod kini nga feature sa sunod nga update, Boss Ian!
                            </div>
                        </div>
                    </div>

                    @* -------------------------------------- *@
                    @* TAB 4: MY REVIEWS                      *@
                    @* -------------------------------------- *@
                    <div class="tab-pane fade" id="v-pills-reviews" role="tabpanel">
                        <div class="card border-0 shadow-sm p-4" style="border-radius: 8px;">
                            <h4 class="fw-bold mb-3" style="color: var(--king-blue);">Product Reviews</h4>
                            <p class="text-muted small">Ipadayag ang imong opinyon sa mga produkto nga imong nadawat.</p>
                        </div>
                    </div>

                    @* -------------------------------------- *@
                    @* TAB 5: SETTINGS                        *@
                    @* -------------------------------------- *@
                    <div class="tab-pane fade" id="v-pills-settings" role="tabpanel">
                        <div class="card border-0 shadow-sm p-4" style="border-radius: 8px;">
                            <h4 class="fw-bold mb-3" style="color: var(--king-blue);">Security & Settings</h4>
                            <p class="text-muted small">I-manage ang imong password ug account safety configurations.</p>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    }
    else
    {
        <div class="py-5 text-center">
            <i class="bi bi-person-x display-4 text-muted"></i>
            <p class="mt-3 text-dark">User profile not found.</p>
            <a href="/" class="btn btn-outline-primary btn-sm px-4" style="border-color: var(--king-blue); color: var(--king-blue);">Return Home</a>
        </div>
    }
</div>


@* ======================================================== *@
@* REUSABLE BOOTSTRAP MODAL POPUP FOR DYNAMIC ORDER DETAILS *@
@* ======================================================== *@
<div class="modal fade" id="orderDetailModal" tabindex="-1" aria-labelledby="orderDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content border-0 shadow" style="border-radius: 12px; background-color: #ffffff;">

            <div class="modal-header border-bottom p-4" style="border-top: 5px solid var(--bhub-cyan) !important;">
                <h5 class="modal-title fw-bold text-dark" id="orderDetailModalLabel">
                    <i class="bi bi-receipt text-marie me-2"></i> Detalye sa Order
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-4" id="modalOrderBody">
                @* LOADER SPINNER *@
                <div class="text-center py-4" id="modalLoader">
                    <div class="spinner-border text-primary" role="status" style="color: var(--king-blue) !important;"><span class="visually-hidden">Loading...</span></div>
                    <p class="text-muted small mt-2 mb-0">Gikuha ang detalye sa server, Boss...</p>
                </div>

                @* DYNAMIC CONTENT AREA *@
                <div id="modalOrderContent" class="d-none">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="small text-muted">Order ID: <strong class="text-dark" id="mdOrderNo">#BH-0000</strong></span>
                        <span class="badge rounded-pill px-3 py-2 fw-medium text-uppercase" id="mdStatus">Pending</span>
                    </div>
                    <hr class="opacity-50">

                    <label class="text-muted small fw-bold text-uppercase mb-1" style="font-size: 0.65rem; letter-spacing: 0.5px;">Gipamalit nga mga Item</label>
                    <div class="list-group list-group-flush mb-3" id="mdItemsList">
                    </div>

                    <div class="p-3 bg-light rounded border-0 small mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Subtotal:</span>
                            <span class="fw-semibold text-dark" id="mdSubtotal">₱0.00</span>
                        </div>
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Shipping Fee:</span>
                            <span class="fw-semibold text-dark">₱50.00</span>
                        </div>
                        <div class="d-flex justify-content-between pt-2 border-top mt-2">
                            <span class="fw-bold text-dark">Total Bill:</span>
                            <span class="fw-bold text-marie" id="mdTotal" style="color: var(--king-blue) !important; font-size: 1.05rem;">₱0.00</span>
                        </div>
                    </div>

                    <div class="small">
                        <label class="text-muted small fw-bold text-uppercase mb-1" style="font-size: 0.65rem; letter-spacing: 0.5px;">Delivery Address</label>
                        <p class="text-dark mb-0 fw-medium"><i class="bi bi-geo-alt text-danger me-1"></i> <span id="mdAddress">Bantayan, Cebu</span></p>
                    </div>
                </div>
            </div>

            <div class="modal-footer border-0 p-4 pt-0">
                <button type="button" class="btn btn-secondary w-100 fw-bold py-2 btn-sm rounded-pill" data-bs-dismiss="modal">I-close</button>
            </div>
        </div>
    </div>
</div>

@* ========================================== *@
@* JAVASCRIPT / AJAX FETCH FOR VIEWING MODAL   *@
@* ========================================== *@
@section Scripts {
    <script>
        function viewOrderDetails(orderId) {
            const myModal = new bootstrap.Modal(document.getElementById('orderDetailModal'));
            document.getElementById('modalLoader').classList.remove('d-none');
            document.getElementById('modalOrderContent').classList.add('d-none');
            myModal.show();

            fetch('/Orders/GetOrderId/' + orderId)
                .then(response => {
                    if (!response.ok) throw new Error("HTTP error, status = " + response.status);
                    return response.json();
                })
                .then(data => {
                    if (data) {
                        document.getElementById('mdOrderNo').innerText = '#BH-' + data.orderId;
                        document.getElementById('mdAddress').innerText = data.shippingAddress || "Default Delivery Address";
                        document.getElementById('mdTotal').innerText = '₱' + data.totalPrice.toLocaleString('en-US', { minimumFractionDigits: 2 });
                        document.getElementById('mdSubtotal').innerText = '₱' + (data.totalPrice - 50).toLocaleString('en-US', { minimumFractionDigits: 2 });

                        const statusBadge = document.getElementById('mdStatus');
                        statusBadge.innerText = data.status;
                        statusBadge.className = "badge rounded-pill px-3 py-2 fw-medium text-uppercase";

                        if (data.status === "Pending") statusBadge.classList.add("bg-warning-subtle", "text-warning");
                        else if (data.status === "Completed") statusBadge.style = "background-color: rgba(46, 125, 50, 0.1) !important; color: var(--dev-green) !important;";
                        else statusBadge.classList.add("bg-danger-subtle", "text-danger");

                        const itemsListContainer = document.getElementById('mdItemsList');
                        itemsListContainer.innerHTML = "";

                        if (data.orderItems && data.orderItems.length > 0) {
                            data.orderItems.forEach(item => {
                                itemsListContainer.innerHTML += `
                                    <div class="list-group-item bg-transparent px-0 border-0 d-flex justify-content-between align-items-center py-2">
                                        <div class="small">
                                            <h6 class="mb-0 fw-semibold text-dark">${item.product.name}</h6>
                                            <small class="text-muted">Qty: ${item.quantity}</small>
                                        </div>
                                        <span class="small fw-medium text-dark">₱${(item.price * item.quantity).toFixed(2)}</span>
                                    </div>`;
                            });
                        } else {
                            itemsListContainer.innerHTML = `<p class="text-muted small mb-0 py-2">Order status: ${data.status}.</p>`;
                        }

                        document.getElementById('modalLoader').classList.add('d-none');
                        document.getElementById('modalOrderContent').classList.remove('d-none');
                    }
                })
                .catch(err => {
                    console.error("Error Fetching Profile Order details:", err);
                    myModal.hide();

                    // Swal Notification Error Block
                    Swal.fire({
                        icon: 'error',
                        title: 'Sipyat, Boss!',
                        text: 'Dili makuha ang mga detalye gikan sa server karong panahona. Palihug sulayi pag-usab.',
                        confirmButtonColor: '#0047AB' // Matched to King Blue
                    });
                });
        }
    </script>
}