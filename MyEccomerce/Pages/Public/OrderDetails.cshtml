@model MyEccomerce.Models.Order

@{
    ViewData["Title"] = $"Order Details #{Model.OrderId}";

    var (badgeStyle, statusIcon) = Model.Status switch
    {
        "Pending" => ("background: #e8f5e9; color: #2e7d32; border: 1px solid #c8e6c9;", "bi-clock-history"),
        "Confirmed" => ("background: #e3f2fd; color: #1565c0; border: 1px solid #bbdefb;", "bi-check2-circle"),
        "Out for Delivery" => ("background: #e0f7fa; color: #00838f; border: 1px solid #b2ebf2;", "bi-truck"),
        "Completed" => ("background: linear-gradient(135deg, #e0f7fa, #e3f2fd); color: #006064; border: 1px solid #00bcd4;", "bi-patch-check-fill"),
        "Cancelled" => ("background: #ffebee; color: #c62828; border: 1px solid #ffcdd2;", "bi-x-circle"),
        _ => ("background: #f5f5f5; color: #424242; border: 1px solid #e0e0e0;", "bi-info-circle")
    };
}

<style>
    .theme-card-header {
        background: linear-gradient(135deg, #1565c0 0%, #00838f 50%, #2e7d32 100%);
    }

    /* Individual hidden classes */
    .text-marie {
        color: #1565c0 !important;
    }

    .i-text {
        color: #2e7d32 !important;
    }

    /* Ang tago nga kombinasyon: .im-cyan (i + m = cyan) */
    .im-cyan {
        color: #00a8cc !important;
    }

    .border-im {
        border-color: #00bcd4 !important;
    }

    .border-marie {
        border-color: #1565c0 !important;
    }

    .border-i {
        border-color: #2e7d32 !important;
    }

    .bg-light-cyan {
        background-color: #f0fbfd !important;
    }

    .border-gradient-accent {
        border-top: 4px solid transparent;
        border-image: linear-gradient(to right, #1565c0, #00bcd4, #2e7d32) 1;
    }
</style>

<div class="container mt-4 pb-5" style="max-width: 800px;">
    <a href="/Orders/MyOrders" class="btn btn-link text-decoration-none p-0 mb-3 text-dark fw-semibold">
        <i class="bi bi-arrow-left text-marie"></i> Balik sa Akong mga Order
    </a>

    <div class="card shadow border-0" style="border-radius: 16px; overflow: hidden;">
        <div class="card-header theme-card-header text-white p-4">
            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2">
                <div>
                    <h4 class="mb-1 fw-bold text-white">Order Details</h4>
                    <span class="text-white-50">ID: #@Model.OrderId</span> • <small class="opacity-75">@Model.OrderDate.ToString("MMMM dd, yyyy hh:mm tt")</small>
                </div>
                <span class="badge rounded-pill px-3 py-2 fs-6 fw-semibold shadow-sm" style="@badgeStyle">
                    <i class="bi @statusIcon"></i> @Model.Status.ToUpper()
                </span>
            </div>
        </div>

        <div class="card-body p-4">
            <div class="mb-4">
                <h6 class="fw-bold text-dark"><i class="bi bi-geo-alt-fill text-marie"></i> Delivery Address</h6>
                <p class="text-muted small mb-0 ps-4">@Model.DeliveryAddress</p>
            </div>

            <hr class="text-muted opacity-25">

            <h6 class="fw-bold text-dark mb-3"><i class="bi bi-basket3-fill i-text"></i> Mga Items nga Gi-order</h6>
            <div class="list-group list-group-flush mb-4">
                @if (Model.OrderItems != null)
                {
                    foreach (var item in Model.OrderItems)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3 border-light">
                            <div class="d-flex align-items-center overflow-hidden">
                                <img src="@(item.Variant != null && !string.IsNullOrEmpty(item.Variant.ImageUrl) ? item.Variant.ImageUrl : (item.Product != null && !string.IsNullOrEmpty(item.Product.ImageUrl) ? item.Product.ImageUrl : "/images/no-image.png"))"
                                     class="border rounded-3 shadow-sm" style="width: 60px; height: 60px; object-fit: cover;" alt="Product" />
                                <div class="ms-3 overflow-hidden">
                                    <h6 class="mb-0 fw-bold text-dark small text-truncate">@item.Product?.Name</h6>
                                    <div class="text-muted mt-1" style="font-size: 0.75rem;">
                                        @if (item.Variant != null)
                                        {
                                            <span class="badge text-dark border me-1" style="background-color: #e0f7fa; border-color: #00bcd4 !important;">@item.Variant.VariationName</span>
                                        }
                                        <span>Qty: @item.Quantity</span> x ₱@item.Price.ToString("N2")
                                    </div>
                                </div>
                            </div>
                            <span class="fw-bold text-dark ps-2">₱@((item.Quantity * item.Price).ToString("N2"))</span>
                        </div>
                    }
                }
            </div>

            <div class="bg-light-cyan rounded-3 p-3 d-flex justify-content-between align-items-center mb-4 border border-info-subtle">
                <span class="fw-bold text-secondary">Kinatibuk-ang Bayranan (Total)</span>
                <span class="fw-bold fs-4 im-cyan">₱@Model.TotalAmount.ToString("N2")</span>
            </div>

            @if (Model.OrderLogs != null && Model.OrderLogs.Any())
            {
                <div class="border-top border-gradient-accent pt-4">
                    <h6 class="fw-bold text-dark mb-3"><i class="bi bi-activity im-cyan"></i> Order History & Progress</h6>
                    <div class="timeline-container ms-2">
                        @foreach (var log in Model.OrderLogs.OrderByDescending(l => l.LogDate))
                        {
                            var (logIcon, logColorClass, dotBorderClass) = log.Status switch
                            {
                                "Order Placed" => ("bi-cart-plus", "i-text", "border-i"),
                                "Pending" => ("bi-clock-history", "i-text", "border-i"),
                                "Confirmed" => ("bi-check2-circle", "text-marie", "border-marie"),
                                "Processing" => ("bi-gear-wide-connected", "text-marie", "border-marie"),
                                "Out for Delivery" => ("bi-truck", "im-cyan", "border-im"),
                                "Completed" => ("bi-patch-check-fill", "im-cyan", "border-im"),
                                "Cancelled" => ("bi-x-circle-fill", "text-danger", "border-danger"),
                                _ => ("bi-dot", "text-muted", "border-secondary")
                            };

                            <div class="position-relative ps-4 pb-3 border-start border-2 border-light" style="left: 10px;">
                                <div class="position-absolute d-flex align-items-center justify-content-center bg-white rounded-circle border border-2 @dotBorderClass"
                                     style="width: 26px; height: 26px; left: -14px; top: 0; z-index: 2;">
                                    <i class="bi @logIcon @logColorClass" style="font-size: 0.85rem;"></i>
                                </div>
                                <div class="ms-2">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <p class="mb-0 fw-bold small text-dark">@log.Status</p>
                                        <small class="text-muted" style="font-size: 0.65rem;">@log.LogDate.ToString("MMM dd, yyyy h:mm tt")</small>
                                    </div>
                                    @if (!string.IsNullOrEmpty(log.Note))
                                    {
                                        <p class="mb-0 text-muted lh-sm mt-1" style="font-size: 0.75rem;">@log.Note</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>