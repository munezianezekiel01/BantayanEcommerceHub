<a href="javascript:void(0);" onclick="goBackToList()" class="back-nav" style="color: #000;">
    <i class="bi bi-arrow-left"></i>
</a>

<script>
    function goBackToList() {
        if (typeof window.restoreProductList === "function") {
            window.restoreProductList(); // Tawgon ang function gikan sa main list page
        } else {
            window.location.href = "/"; // Fallback kung gi-direct og load ang URL
        }
    }
</script>

<div class="container">
   <input type="hidden" id="currentUserId" value="@ViewBag.CurrentUserId" />
<input type="hidden" id="currentProductId" value="@Model.ProductId" />

   
    <div class="product-details-card">
        <div class="row">
            <div class="col-md-5">
                <div class="img-main-wrapper">
                    <img id="mainProductImage" src="@Model.ImageUrl" alt="@Model.Name">
                </div>
                <div class="thumb-container">
                    <img src="@Model.ImageUrl" class="thumb-item active-thumb shadow-sm"
                         onclick="syncSelection('@Model.ImageUrl', this, '0')" loading="lazy">
                    @if (Model.ProductVariants != null)
                    {
                        @foreach (var v in Model.ProductVariants.Where(x => !string.IsNullOrEmpty(x.ImageUrl)))
                        {
                            <img src="@v.ImageUrl" class="thumb-item shadow-sm"
                                 onclick="syncSelection('@v.ImageUrl', this, '@v.VariantId')" loading="lazy">
                        }
                    }
                </div>
            </div>

            <div class="col-md-7 ps-md-5">
                <h2 class="fw-bold mb-1">@Model.Name</h2>

                <div class="d-flex align-items-center gap-3 mb-2">
                    <div class="text-warning small">
                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i>
                        <span class="text-muted ms-1">(4.8)</span>
                    </div>
                    <div class="vr"></div>
                    <span class="text-muted small">Sold: <strong>@Model.SoldCount</strong></span>
                    <div class="vr"></div>
                    <span class="text-muted small d-flex align-items-center gap-1">
                        <i class="bi bi-eye text-secondary fs-6"></i> Views: <strong>@Model.ViewCount</strong>
                    </span>
                    <span id="stockStatus" class="stock-badge in-stock">
                        <i class="bi bi-check-circle-fill"></i> <span id="displayStock">@Model.Stock</span> @unitLabel
                    </span>
                </div>

                <div class="price-display" id="displayPrice">
                    ₱@Model.Price.ToString("N2")
                </div>

                @if (Model.ProductVariants != null && Model.ProductVariants.Any())
                {
                    <div class="mb-4">
                        <label class="d-block text-secondary small fw-bold mb-2">Select Variation:</label>
                        <div class="d-flex flex-wrap">
                            @foreach (var variant in Model.ProductVariants)
                            {
                                <button type="button" class="variant-btn"
                                        id="btn-v-@variant.VariantId"
                                        data-variantid="@variant.VariantId"
                                        data-price="@variant.Price"
                                        data-stock="@variant.Stock"
                                        data-img="@variant.ImageUrl"
                                        onclick="selectVariant(this)">
                                    @variant.VariationName
                                </button>
                            }
                        </div>
                    </div>
                }

                <div class="mb-4">
                    <label class="d-block text-secondary small fw-bold mb-2">@qtyLabel:</label>
                    <div class="qty-wrapper">
                        <button class="qty-btn" onclick="updateQty(-1)">&minus;</button>
                        <input type="text" id="qtyBox" value="1" readonly>
                        <button class="qty-btn" onclick="updateQty(1)">&plus;</button>
                    </div>
                </div>

                <div class="d-grid d-md-flex gap-3 mt-4">
                    <button class="btn btn-cart px-4" onclick="handleAddToCart()">
                        <i class="bi bi-cart-plus fs-5 me-2"></i> Add to Cart
                    </button>
                    <button class="btn btn-buy px-5" onclick="buyNow()">Buy Now</button>
                </div>

                <div class="mt-4 p-3 info-card rounded-3 small">
                    <div class="d-flex gap-3 mb-2">
                        <i class="bi bi-house-door text-danger fs-5"></i>
                        <div>
                            <strong>Delivery Info:</strong><br>
                            <span class="text-muted">
                                • Orders ₱500 - ₱999: <strong>₱50 Delivery Charge</strong><br>
                                • Orders ₱1,000 up: <strong>Libre ang Hatod (FREE)</strong><br>
                                <small class="text-secondary">*Applicable within Bantayan, Santa Fe, & Madridejos</small>
                            </span>
                        </div>
                    </div>
                </div>

                <input type="hidden" id="selectedVariantId" value="" />
                <input type="hidden" id="basePrice" value="@Model.Price" />
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    // 1. Sync Selection (Clicking Thumbnails)
    function syncSelection(imgUrl, thumb, variantId) {
        document.getElementById('mainProductImage').src = imgUrl;

        // Highlight Thumbnail
        document.querySelectorAll('.thumb-item').forEach(t => t.classList.remove('active-thumb'));
        thumb.classList.add('active-thumb');

        // I-click ang button nga kapares sa thumbnail
        if(variantId !== '0') {
            const btn = document.getElementById('btn-v-' + variantId);
            if(btn) selectVariant(btn, false);
        }
    }

    // 2. Select Variant (Clicking Variation Buttons)
    function selectVariant(element, updateImg = true) {
        const vId = element.getAttribute('data-variantid');
        const price = parseFloat(element.getAttribute('data-price'));
        const stock = element.getAttribute('data-stock');
        const img = element.getAttribute('data-img');

        // UI: Highlight napili
        document.querySelectorAll('.variant-btn').forEach(b => b.classList.remove('active'));
        element.classList.add('active');

        // Logic: Save values
        document.getElementById('selectedVariantId').value = vId;
        document.getElementById('basePrice').value = price;

        // Update Stock Display
        document.getElementById('displayStock').innerText = stock;

        // Stock Badge Logic
        const badge = document.getElementById('stockStatus');
        if(parseInt(stock) <= 5) {
            badge.className = "stock-badge low-stock";
        } else {
            badge.className = "stock-badge in-stock";
        }

        // Sync Image kon naay picture ang variant
        if (updateImg && img && img !== "") {
            document.getElementById('mainProductImage').src = img;
            document.querySelectorAll('.thumb-item').forEach(t => {
                t.classList.toggle('active-thumb', t.src.includes(img));
            });
        }

        calculateLivePrice();
    }

    // 3. Update Quantity
    function updateQty(amt) {
        const box = document.getElementById('qtyBox');
        let current = parseInt(box.value) || 1;
        let next = current + amt;

        if (next >= 1) {
            box.value = next;
            calculateLivePrice();
        }
    }

    // 4. Calculate Total Price
    function calculateLivePrice() {
        const base = parseFloat(document.getElementById('basePrice').value) || 0;
        const qty = parseInt(document.getElementById('qtyBox').value) || 1;
        const total = base * qty;

        const formatter = new Intl.NumberFormat('en-US', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });

        document.getElementById('displayPrice').innerText = "₱" + formatter.format(total);
    }

    // 5. AJAX Add to Cart
       // 5. AJAX Add to Cart (Gidugangan og isBuyNow parameter)
    async function handleAddToCart(isBuyNow = false) {
        let variantId = document.getElementById('selectedVariantId').value;
        let qty = parseInt(document.getElementById('qtyBox').value);
        let productId = "@Model.ProductId";

        const hasVariants = document.querySelectorAll('.variant-btn').length > 0;
        if (hasVariants && !variantId) {
            Swal.fire({
                icon: 'warning',
                title: 'Pili una, boss!',
                text: 'Palihug pagpili og variation (sama sa 250g o 500g) sa dili pa mopalit.'
            });
            return false;
        }

        try {
            const response = await fetch('/Cart/AddToCart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    'productId': productId,
                    'variantId': variantId || 0,
                    'quantity': qty
                })
            });

            const result = await response.json();

            if (result.success) {
                // KANI NGA BAHIN: Mo-gawas lang ang popup kung DILI Buy Now ang gi-click
                if (!isBuyNow) {
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'success',
                        title: 'Na-add na sa cart!',
                        showConfirmButton: false,
                        timer: 1500
                    });

                    
                }

                const badge = document.getElementById('cartBadgeCount');
                if (badge && result.cartCount !== undefined) {
                    badge.innerText = result.cartCount;
                    badge.style.display = 'inline-block';
                }
                return true;
            } else {
                Swal.fire({ icon: 'error', title: 'Ops!', text: result.message });
                return false;
            }
        } catch (error) {
            console.error("Error:", error);
            return false;
        }
    }

    // 6. Buy Now
    function buyNow() {
        handleAddToCart().then(success => {
            if(success) window.location.href = '/Cart/Checkout';
        });
    }

    // 7. Auto-load settings
    document.addEventListener("DOMContentLoaded", () => {
        const firstVariant = document.querySelector('.variant-btn');
        if (firstVariant) {
            firstVariant.click();
        } else {
            calculateLivePrice();
        }
    });
</script>


        <script>

           // --- 1. GUEST ID SYSTEM ---
    if (!localStorage.getItem('bhub_guest_id')) {
        let randomId = 'GUEST-' + Math.random().toString(36).substring(2, 11).toUpperCase() + '-' + Date.now();
        localStorage.setItem('bhub_guest_id', randomId);
    }
    let myGuestId = localStorage.getItem('bhub_guest_id');

    // --- 2. TIME TRACKER VARIABLES (KINI ANG IMPORTANTE NGA FIX, BOSS!) ---
    let secondsSpent = 0;
    let trackerInterval = 0; // <<< KINI DAPAT KAAUGALINGON NGA DEKLARASYON SA GAWAS SA FUNCTION!

       

    // 1. Sugdan ang timer inig load sa page
    function startTracking() {
        secondsSpent = 0; // reset
        trackerInterval = setInterval(function () {
            secondsSpent++;
            console.log("Time spent:", secondsSpent); // Para makita nimo sa console nga nag-ihap siya
        }, 1000);
    }

    // 2. Tawgon lang kini INIG BIYA sa user sa page (pananglitan, sa `beforeunload` event)
    function sendTimeToDatabase() {
        // I-check kon abot ba og 2 segundos pataas
        if (secondsSpent < 2) {
            console.warn("Tracking skipped: Wala kaabot og 2 segundos.");
            return;
        }

        if (trackerInterval) {
            clearInterval(trackerInterval);
        }

        let registeredUserId = document.getElementById('currentUserId')?.value || "";
        let anonymousGuestId = (typeof myGuestId !== 'undefined') ? myGuestId : "GUEST_USER";
        let productId = document.getElementById('currentProductId')?.value || 0;

        let url = "/Product/SaveTimeSpent";
        let formData = new FormData();
        formData.append("authUserId", registeredUserId);
        formData.append("guestSessionId", anonymousGuestId);
        formData.append("productId", productId);
        formData.append("seconds", secondsSpent); // Karon, dili na kini 0

        fetch(url, {
            method: "POST",
            body: formData,
            keepalive: true
        }).catch(err => console.error("Fetch tracking error:", err));
    }

    // Mo-andar inig sulod sa page
    window.addEventListener('DOMContentLoaded', (event) => {
        startTracking();
    });

    // Mo-send sa data inig close o biya sa page
    window.addEventListener('beforeunload', function () {
        sendTimeToDatabase();
    });

    // Pagbira sa hitabo sa pagsira sa tab o window
    document.addEventListener("visibilitychange", function() {
        if (document.visibilityState === "hidden") { sendTimeToDatabase(); }
    });
    window.addEventListener("pagehide", function() { sendTimeToDatabase(); });

    // 4. Sync Selection (Clicking Thumbnails)
    function syncSelection(imgUrl, thumb, variantId) {
        document.getElementById('mainProductImage').src = imgUrl;
        document.querySelectorAll('.thumb-item').forEach(t => t.classList.remove('active-thumb'));
        thumb.classList.add('active-thumb');

        if(variantId !== '0') {
            const btn = document.getElementById('btn-v-' + variantId);
            if(btn) selectVariant(btn, false);
        }
    }

   
        </script>