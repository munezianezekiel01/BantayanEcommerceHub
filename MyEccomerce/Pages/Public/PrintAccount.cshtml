@model IEnumerable<dynamic>
@{
    Layout = null;
    // Kuhaon ang data gikan sa Claims
    var pictureUrl = Model.FirstOrDefault(c => c.Type == "picture")?.Value;
    var firstName = Model.FirstOrDefault(c => c.Type.Contains("givenname"))?.Value;
    var lastName = Model.FirstOrDefault(c => c.Type.Contains("surname"))?.Value;
    var email = Model.FirstOrDefault(c => c.Type.Contains("emailaddress"))?.Value;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account Verified | MyEcommerce</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body {
            background-color: #f0f2f5; /* Facebook Gray Background */
            font-family: Helvetica, Arial, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }

        .fb-card {
            background: #fff;
            width: 100%;
            max-width: 500px;
            border-radius: 12px;
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
            overflow: hidden;
            animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @@keyframes popIn {
            from {
                opacity: 0;
                transform: scale(0.9);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .cover-photo {
            height: 120px;
            background: linear-gradient(to right, #1877f2, #0056b3);
            position: relative;
        }

        .profile-section {
            text-align: center;
            margin-top: -60px;
            padding: 0 20px 20px 20px;
            position: relative;
        }

        .user-img-container {
            position: relative;
            display: inline-block;
        }

        .user-img {
            width: 130px;
            height: 130px;
            border-radius: 50%;
            border: 4px solid #fff;
            background: #eee;
            object-fit: cover;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .online-dot {
            position: absolute;
            bottom: 12px;
            right: 12px;
            width: 24px;
            height: 24px;
            background: #31a24c;
            border: 4px solid #fff;
            border-radius: 50%;
        }

        .user-info h2 {
            font-size: 24px;
            font-weight: 700;
            margin: 10px 0 0 0;
            color: #050505;
        }

        .user-info .email {
            color: #65676b;
            font-size: 15px;
            margin-bottom: 20px;
            display: block;
        }

        .data-grid {
            background: #f7f8fa;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
            text-align: left;
        }

        .data-item {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid #ebedf0;
        }

            .data-item:last-child {
                border: none;
            }

        .label {
            color: #65676b;
            font-size: 13px;
            font-weight: 600;
        }

        .value {
            color: #050505;
            font-size: 14px;
            font-weight: 400;
        }

        .btn-fb-primary {
            background-color: #1877f2;
            color: #fff;
            border: none;
            width: 100%;
            padding: 10px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 16px;
            margin-bottom: 10px;
            transition: 0.2s;
            text-decoration: none;
            display: inline-block;
        }

            .btn-fb-primary:hover {
                background-color: #166fe5;
                color: #fff;
            }

        .btn-fb-logout {
            background-color: #e4e6eb;
            color: #050505;
            border: none;
            width: 100%;
            padding: 10px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 16px;
            transition: 0.2s;
            text-decoration: none;
            display: inline-block;
        }

            .btn-fb-logout:hover {
                background-color: #d8dadf;
                color: #050505;
            }

        .verified-text {
            color: #1877f2;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 15px;
            display: block;
        }
    </style>
</head>
<body>

    <div class="fb-card">
        <div class="cover-photo"></div>

        <div class="profile-section">
            <div class="user-img-container">
                @if (!string.IsNullOrEmpty(pictureUrl))
                {
                    <img src="@pictureUrl" class="user-img" referrerpolicy="no-referrer" alt="Profile Picture" />
                }
                else
                {
                    <div class="user-img d-flex align-items-center justify-content-center bg-light">
                        <i class="fas fa-user fa-3x text-secondary"></i>
                    </div>
                }
                <div class="online-dot"></div>
            </div>

            <div class="user-info text-center">
                <h2>@firstName @lastName <i class="fas fa-check-circle" style="color: #1877f2; font-size: 18px;" title="Verified Profile"></i></h2>
                <span class="email">@email</span>
                <span class="verified-text"><i class="fas fa-shield-alt"></i> Account Secured by Google</span>
            </div>

            <div class="data-grid">
                <div class="data-item">
                    <span class="label">First Name</span>
                    <span class="value">@firstName</span>
                </div>
                <div class="data-item">
                    <span class="label">Last Name</span>
                    <span class="value">@lastName</span>
                </div>
                <div class="data-item">
                    <span class="label">Auth Provider</span>
                    <span class="value text-primary">Google Cloud</span>
                </div>
                <div class="data-item">
                    <span class="label">DB Sync</span>
                    <span class="value text-success">Active</span>
                </div>
            </div>

            <a href="/" class="btn-fb-primary shadow-sm">
                <i class="fas fa-home me-2"></i> Go to Dashboard
            </a>

            <a asp-controller="Account" asp-action="Logout" class="btn-fb-logout mt-2">
                <i class="fas fa-sign-out-alt me-2"></i> Logout and Reset Session
            </a>

        </div>

        <div class="text-center pb-3">
            <small class="text-muted" style="font-size: 10px; letter-spacing: 1px;">MYECOMMERCE IDENTITY SERVICE © 2026</small>
        </div>
    </div>

</body>
</html>