@model string
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Verify Device | MyEcommerce</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: #f0f2f5;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .otp-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 400px;
            text-align: center;
        }

        .otp-input {
            letter-spacing: 10px;
            font-size: 24px;
            text-align: center;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="otp-card">
        <h3 class="fw-bold text-primary">Security Check</h3>
        <p class="text-muted small">Naay ni-login sa laing device. Palihug i-input ang 6-digit code nga gi-send sa <b>@Model</b>.</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2 small">@ViewBag.Error</div>
        }

        <form asp-action="ConfirmOTP" method="post">
            <input type="hidden" name="email" value="@Model" />
            <input type="text" name="otpInput" class="form-control otp-input mb-3" maxlength="6" placeholder="000000" required autofocus />
            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">VERIFY DEVICE</button>
        </form>

        <div class="mt-3">
            <a asp-action="Logout" class="text-decoration-none small text-secondary">Cancel and Logout</a>
        </div>
    </div>
</body>
</html>