@model IEnumerable<MyEccomerce.Models.Order>

@{
    ViewData["Title"] = "Akong mga Order";

    var pendingCount = Model?.Count(o => o.Status == "Pending") ?? 0;
    var confirmedCount = Model?.Count(o => o.Status == "Confirmed") ?? 0;
    var deliveringCount = Model?.Count(o => o.Status == "Out for Delivery") ?? 0;
    var completedCount = Model?.Count(o => o.Status == "Completed") ?? 0;
    var cancelledCount = Model?.Count(o => o.Status == "Cancelled") ?? 0;
}

<a href="javascript:history.back()" class="back-nav ms-3 mt-3 d-inline-block" style="color: #000; font-size: 20px;">
    <i class="bi bi-arrow-left"></i>
</a>

<div class="container-fluid container-md mt-3 mt-md-4 pb-5">

    @* --- HEADER --- *@
    <div class="px-2 px-md-0 mb-3 d-flex align-items-center justify-content-between">
        <h3 class="fw-bold text-dark mb-0 h4 h3-md">
            <i class="bi bi-bag-check-fill text-primary"></i> Akong mga Order
        </h3>
    </div>

    @* --- TABS FILTER --- *@
    <div class="order-tabs-container position-relative mb-4 shadow-sm bg-white" id="tabsWrapper">
        <button class="scroll-arrow left-arrow fade-arrow" id="scrollLeft" type="button">
            <i class="bi bi-chevron-left"></i>
        </button>

        <div class="order-tabs-wrapper">
            <div class="tabs-scroll-container" id="tabsScroll">
                <ul class="nav nav-pills flex-nowrap" id="orderTabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link text-secondary d-flex flex-column align-items-center" data-filter="Pending" href="javascript:void(0)">
                            <div class="icon-wrapper">
                                <i class="bi bi-wallet2"></i>
                                @if (pendingCount > 0)
                                {
                                    <span class="status-badge badge rounded-pill bg-danger">@pendingCount</span>
                                }
                            </div>
                            <span class="tab-label">Pending</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-secondary d-flex flex-column align-items-center" data-filter="Confirmed" href="javascript:void(0)">
                            <div class="icon-wrapper">
                                <i class="bi bi-box-seam"></i>
                                @if (confirmedCount > 0)
                                {
                                    <span id="badge-Confirmed" class="status-badge badge rounded-pill bg-danger">@confirmedCount</span>
                                }
                            </div>
                            <span class="tab-label">Confirmed</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-secondary d-flex flex-column align-items-center" data-filter="Out for Delivery" href="javascript:void(0)">
                            <div class="icon-wrapper">
                                <i class="bi bi-truck"></i>
                                @if (deliveringCount > 0)
                                {
                                    <span class="status-badge badge rounded-pill bg-danger">@deliveringCount</span>
                                }
                            </div>
                            <span class="tab-label">Delivering</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-secondary d-flex flex-column align-items-center" data-filter="Completed" href="javascript:void(0)">
                            <div class="icon-wrapper">
                                <i class="bi bi-check-circle"></i>
                                @if (completedCount > 0)
                                {
                                    <span id="badge-Completed" class="status-badge badge rounded-pill bg-danger">@completedCount</span>
                                }
                            </div>
                            <span class="tab-label">Completed</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-secondary d-flex flex-column align-items-center" data-filter="Cancelled" href="javascript:void(0)">
                            <div class="icon-wrapper">
                                <i class="bi bi-x-octagon"></i>
                                @if (cancelledCount > 0)
                                {
                                    <span id="badge-Cancelled" class="status-badge badge rounded-pill bg-danger">@cancelledCount</span>
                                }
                            </div>
                            <span class="tab-label">Cancelled</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <button class="scroll-arrow right-arrow fade-arrow" id="scrollRight" type="button">
            <i class="bi bi-chevron-right"></i>
        </button>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 shadow-sm bg-white rounded-3 border mx-2">
            <i class="bi bi-cart-x text-muted" style="font-size: 4rem;"></i>
            <p class="mt-3 text-muted">Wala pa kay order, Boss. Sugod na og shop!</p>
            <a href="/" class="btn btn-primary rounded-pill px-4">Shop Karon</a>
        </div>
    }
    else
    {
        <div id="ordersContainer" class="px-2 px-md-0">
            @foreach (var order in Model)
            {
                var (badgeClass, statusIcon) = order.Status switch
                {
                    "Pending" => ("bg-secondary-subtle text-secondary border-secondary", "bi-clock-history"),
                    "Confirmed" => ("bg-primary-subtle text-primary border-primary", "bi-check2-circle"),
                    "Out for Delivery" => ("bg-warning-subtle text-dark border-warning", "bi-truck"),
                    "Completed" => ("bg-success-subtle text-success border-success", "bi-patch-check-fill"),
                    "Cancelled" => ("bg-danger-subtle text-danger border-danger", "bi-x-circle"),
                    _ => ("bg-light text-dark border-dark", "bi-info-circle")
                };

                <div class="card mb-4 shadow-sm order-card border-0" data-status="@order.Status" style="border-radius: 12px; overflow: hidden; display:none;">
                    @* --- CARD HEADER --- *@
                    <div class="card-header bg-marie-im text-white d-flex justify-content-between align-items-center py-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fw-bold">#@order.OrderId</span>
                            <span class="text-white-50">|</span>
                            <small class="opacity-75">@order.OrderDate.ToString("MMM dd, yyyy")</small>
                        </div>
                        <span class="badge @badgeClass d-flex align-items-center gap-1 border-0 rounded-pill px-3 py-2" style="font-size: 0.65rem;">
                            <i class="bi @statusIcon"></i> @order.Status.ToUpper()
                        </span>
                    </div>

                    <div class="card-body p-0">
                        @* --- PRODUCTS LIST --- *@
                        <ul class="list-group list-group-flush">
                            @if (order.OrderItems != null)
                            {
                                foreach (var item in order.OrderItems)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center p-3 border-light">
                                        <div class="d-flex align-items-center flex-grow-1 overflow-hidden">
                                            <img src="@(item.Variant != null && !string.IsNullOrEmpty(item.Variant.ImageUrl) ? item.Variant.ImageUrl : (item.Product != null && !string.IsNullOrEmpty(item.Product.ImageUrl) ? item.Product.ImageUrl : "/images/no-image.png"))"
                                                 class="order-item-img border rounded-3" alt="Product" />
                                            <div class="ms-3 overflow-hidden">
                                                <h6 class="mb-0 fw-bold text-dark text-truncate small">@item.Product?.Name</h6>
                                                <div class="text-muted" style="font-size: 0.7rem;">
                                                    @if (item.Variant != null)
                                                    {
                                                        <span class="text-primary">@item.Variant.VariationName</span>
                                                        <span class="mx-1">|</span>
                                                    }
                                                    <span>Qty: @item.Quantity</span> x ₱@item.Price.ToString("N2")
                                                </div>
                                            </div>
                                        </div>
                                        <div class="text-end fw-bold text-dark small ms-2">₱@((item.Quantity * item.Price).ToString("N2"))</div>
                                    </li>
                                }
                            }
                        </ul>

                        @* --- TIMELINE / PROGRESS --- *@
                        @if (order.OrderLogs != null && order.OrderLogs.Any())
                        {
                            <div class="px-4 py-3 bg-light border-top border-bottom">
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <i class="bi bi-activity text-primary"></i>
                                    <h6 class="fw-bold mb-0 small text-uppercase" style="letter-spacing: 1px;">Order Progress</h6>
                                </div>

                                <div class="timeline-container ms-2">
                                    @foreach (var log in order.OrderLogs.OrderByDescending(l => l.LogDate))
                                    {
                                        var (logIcon, logColor) = log.Status switch
                                        {
                                            "Order Placed" => ("bi-cart-plus", "text-secondary"),
                                            "Pending" => ("bi-clock-history", "text-secondary"),
                                            "Confirmed" => ("bi-check2-circle", "text-primary"),
                                            "Processing" => ("bi-gear-wide-connected", "text-info"),
                                            "Out for Delivery" => ("bi-truck", "text-warning"),
                                            "Completed" => ("bi-patch-check-fill", "text-success"),
                                            "Cancelled" => ("bi-x-circle-fill", "text-danger"),
                                            _ => ("bi-dot", "text-muted")
                                        };

                                        <div class="timeline-item">
                                            <div class="timeline-line"></div>
                                            <div class="timeline-icon @logColor">
                                                <i class="bi @logIcon"></i>
                                            </div>
                                            <div class="timeline-content pb-3 ms-4">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <p class="mb-0 fw-bold small text-dark">@log.Status</p>
                                                    <small class="text-muted" style="font-size: 0.65rem;">@log.LogDate.ToString("MMM dd, h:mm tt")</small>
                                                </div>
                                                @if (!string.IsNullOrEmpty(log.Note))
                                                {
                                                    <p class="mb-0 text-muted lh-sm mt-1" style="font-size: 0.75rem;">@log.Note</p>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    @* --- CARD FOOTER --- *@
                    <div class="card-footer bg-white p-3 border-0">
                        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
                            <div class="d-flex flex-column gap-2">
                                <div class="small text-muted lh-sm" style="max-width: 200px;">
                                    <i class="bi bi-geo-alt-fill text-danger"></i> @order.DeliveryAddress
                                </div>

                                <div class="d-flex flex-wrap gap-2 mt-2">
                                    @if (order.Status == "Pending")
                                    {
                                        @* GI-REPLACE ANG FORM NGADTO SA SMART BUTTON PARA SA AJAX *@
                                        <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3 py-1"
                                                onclick="executeCancelOrder(@order.OrderId)"
                                                style="font-size: 0.65rem; font-weight: 700;">
                                            <i class="bi bi-x-circle-fill"></i> CANCEL ORDER
                                        </button>
                                    }

                                    @if (order.Status == "Completed")
                                    {
                                        <a href="/Home" class="btn btn-primary btn-sm px-3 rounded-pill" style="font-size: 0.65rem; font-weight: 700;">
                                            <i class="bi bi-arrow-repeat"></i> BUY AGAIN
                                        </a>

                                        <a asp-action="DownloadInvoice" asp-route-id="@order.OrderId" class="btn btn-outline-danger btn-sm px-3 rounded-pill" style="font-size: 0.65rem; font-weight: 700;">
                                            <i class="bi bi-file-earmark-pdf-fill"></i> INVOICE PDF
                                        </a>

                                        <form asp-action="ArchiveOrder" method="post" onsubmit="return confirm('I-hide kini, Boss?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="orderId" value="@order.OrderId" />
                                            <button type="submit" class="btn btn-outline-secondary btn-sm px-3 rounded-pill" style="font-size: 0.65rem; font-weight: 700;">
                                                <i class="bi bi-eye-slash"></i> HIDE
                                            </button>
                                        </form>
                                    }

                                    @if(order.Status == "Cancelled")
                                    {
                                        <form asp-action="ArchiveOrder" method="post" onsubmit="return confirm('I-hide kini, Boss?');" >
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="orderId" value="@order.OrderId" />
                                            <button type="submit" class="btn btn-outline-secondary btn-sm px-3 rounded-pill" style="font-size: 0.65rem; font-weight: 700;">
                                                <i class="bi bi-eye-slash"></i> HIDE
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>

                            <div class="text-sm-end align-self-end align-self-sm-center">
                                <span class="small text-muted d-block" style="font-size: 0.7rem;">Total Amount</span>
                                <span class="text-primary fw-bold fs-5">₱@order.TotalAmount.ToString("N2")</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div id="emptyFilterState" class="text-center py-5 bg-white rounded-3 border mx-2 shadow-sm" style="display: none;">
            <i class="bi bi-search text-muted" style="font-size: 3rem;"></i>
            <p class="mt-3 text-muted">Walay order dinhi, Boss.</p>
        </div>
    }
</div>



@section Scripts {
    <script>
        // 1. KINI ANG LABING CHUY NGA AJAX CANCEL LOGIC
        function executeCancelOrder(id) {
            Swal.fire({
                title: 'Sigurado ka, Boss?',
                text: "Gusto ba nimo i-cancel kini nga order?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Oo, I-cancel!',
                cancelButtonText: 'Ayaw lang'
            }).then((result) => {
                if (result.isConfirmed) {

                    // URL endpoint sa imong controller action
                    fetch('/Orders/CancelOrder?orderId=' + id, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                                if (data.success) {
            Swal.fire({
                icon: 'success',
                title: 'Selyado, Boss!',
                text: data.message,
                confirmButtonColor: '#3085d6'
            }).then(() => {
                // AUTOMATIC NING MO-REDIRECT BALIK SA KUNG UNSAY SAKTONG URL ROTHA SA IMONG PAGE KARON
                // Ug dugangan lang niya og '?status=Cancelled' aron mo-click diritso ang Cancelled tab!
                window.location.href = window.location.pathname + '?status=Cancelled';
            });
        }
                    })
                    .catch(err => {
                        console.error("Error:", err);
                        Swal.fire('Error', 'Dili makakonektar sa server, Boss.', 'error');
                    });
                }
            });
        }

        // 2. KANHI IMONG EXISTING FILTER LOGIC (Gi-wasto para sa URL strings)
        function filterOrders(status) {
            const cards = document.querySelectorAll('.order-card');
            const tabs = document.querySelectorAll('#orderTabs .nav-link');
            const emptyState = document.getElementById('emptyFilterState');
            let foundCount = 0;

            tabs.forEach(t => {
                const isTarget = t.getAttribute('data-filter') === status;
                t.classList.toggle('active', isTarget);
                t.classList.toggle('text-secondary', !isTarget);
            });

            cards.forEach(card => {
                const cardStatus = card.getAttribute('data-status');
                const isMatch = cardStatus === status;
                card.style.setProperty('display', isMatch ? 'block' : 'none', 'important');
                if (isMatch) foundCount++;
            });

            if (emptyState) emptyState.style.display = foundCount === 0 ? 'block' : 'none';
        }

        const container = document.getElementById('tabsScroll');
        const btnLeft = document.getElementById('scrollLeft');
        const btnRight = document.getElementById('scrollRight');

        function showArrows() {
            if (!container) return;
            const maxScroll = container.scrollWidth - container.clientWidth;
            if(btnLeft) btnLeft.classList.toggle('show', container.scrollLeft > 10);
            if(btnRight) btnRight.classList.toggle('show', container.scrollLeft < maxScroll - 10);
        }

        window.addEventListener('DOMContentLoaded', () => {
            // Unahon og tsek kung naa bay '?status=' sa URL query string, kung wala, gamiton ang ViewBag o default 'Pending'
            const urlParams = new URLSearchParams(window.location.search);
            const targetStatus = urlParams.get('status') || '@ViewBag.TargetStatus' || 'Pending';

            setTimeout(() => { 
                filterOrders(targetStatus);
                showArrows();
            }, 50);
        });

        document.querySelectorAll('#orderTabs .nav-link').forEach(tab => {
            tab.addEventListener('click', function() {
                const status = this.getAttribute('data-filter');
                filterOrders(status);

                // I-update sab ang URL string para clean tan-awon
                const newUrl = window.location.protocol + "//" + window.location.host + window.location.pathname + '?status=' + status;
                window.history.pushState({ path: newUrl }, '', newUrl);
            });
        });

        if(container) {
            container.addEventListener('scroll', showArrows);
            if(btnLeft) btnLeft.addEventListener('click', () => container.scrollBy({ left: -200, behavior: 'smooth' }));
            if(btnRight) btnRight.addEventListener('click', () => container.scrollBy({ left: 200, behavior: 'smooth' }));
        }
    </script>


    <script>

                document.addEventListener("DOMContentLoaded", function () {
            // Basahon ang ?status= gikan sa URL browser bar
            const urlParams = new URLSearchParams(window.location.search);
            const actualStatus = urlParams.get('status') || "Pending";

            // I-trigger ang pag-abli sa Order History Tab automatic
            const orderTabBtn = document.getElementById("v-pills-orders-tab");
            if (orderTabBtn) {
                orderTabBtn.click(); // Awtomatiko kining mopindot sa Order History tab
            }

            // Filter sa rows para ipakita ang actual status ra gyud
            const rows = document.querySelectorAll("#v-pills-orders table tbody tr");
            rows.forEach(row => {
                const badge = row.querySelector(".badge");
                if (badge) {
                    const badgeText = badge.innerText.trim().toLowerCase();
                    if (badgeText.includes(actualStatus.toLowerCase())) {
                        row.style.display = ""; // Ipakita ang ka-match sa actual status
                    } else {
                        row.style.display = "none"; // I-tago ang uban
                    }
                }
            });
        });
    </script>


    <script>


    </script>
}