                    </ul>
                </div>

                <div class="col-lg-2 col-md-6 col-6">
                    <h6 class="fw-bold mb-3">Tabang</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="#" class="text-muted text-decoration-none">FAQs</a></li>
                        <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Shipping Info</a></li>
                        <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Refund Policy</a></li>
                    </ul>
                </div>

                <div class="col-lg-4 col-md-6 text-md-end">
                    <h6 class="fw-bold mb-3">Modawat Kami Og</h6>
                    <div class="d-flex gap-2 justify-content-md-end">
                        @* <span class="badge bg-light text-dark border p-2 small">GCash</span>
                        <span class="badge bg-light text-dark border p-2 small">Maya</span> *@
                        <span class="badge bg-light text-dark border p-2 small">COD</span>
                    </div>
                </div>
            </div>
            <hr class="my-4 text-muted">
            <div class="text-center">
                <p class="small text-muted mb-0">&copy; @DateTime.Now.Year B-HUB Ecommerce. All rights reserved.</p>
            </div>
        </div>
    </footer>
   
    
    <script src="~/js/timeStamp.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>



    //proper order 
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/CartSidebar.js"></script>
    <script src="~/js/updateBadge.js"></script>
    <script src="~/js/NotificationLogic.js"></script>
    
     
   
    <script src="~/js/site.js" type="module"></script>
    <script src="~/js/timeStamp.js"></script>
    <script src="~/js/SearchInnput.js"></script>
    <script src="~/js/SearchInputMobile.js"></script>
    <script src="~/js/signalr.min.js"></script>

         
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/updateHub")
            .withAutomaticReconnect()
            .build();

        connection.on("NewUpdateAlert", (data) => {
            // Patugtugon ang audio
            new Audio('https://actions.google.com/sounds/v1/alarms/beep_short.ogg').play().catch(e => console.log(e));

            // Swal Alert nga naay saktong data gikan sa backend
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'success',
                title: `Ang imong Order #${data.orderId} kay ${data.status} na!`,
                showConfirmButton: false,
                timer: 3000
            });

            // I-reload ang page human sa 3.2 segundos aron makita ang bag-ong data sa screen
            setTimeout(() => { location.reload(); }, 3200);
        });

        connection.start().then(function () {
            var userId = "@User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier)";
            if (userId) {
                // Kung Pamaagi A imong gigamit, sakto nani:
                connection.invoke("JoinUserGroup", userId);
            }
        }).catch(function (err) {
            return console.error(err.toString());
        });
    </script>

    <script>
                document.addEventListener('DOMContentLoaded', function () {
            // --- ADVERTISEMENT LOGIC (Kausa ra matag 24 oras) ---
            const adModalElement = document.getElementById('advertisementModal');

            if (adModalElement) {
                const adModal = new bootstrap.Modal(adModalElement);
                const lastShown = localStorage.getItem('bhub_ad_last_shown');
                const now = new Date().getTime();

                // 24 oras sa milliseconds (24 * 60 * 60 * 1000)
                const ONE_DAY = 86400000;

                // Kon wala pa kabisita O nalapas na ang 24 oras gikan sa katong nakakita siya
                if (!lastShown || (now - lastShown) > ONE_DAY) {

                    // Butangan natog gamay nga delay (2 segundos) inig open sa page para hapsay ang transition
                    setTimeout(() => {
                        adModal.show();
                        // I-save ang petsa/oras karon sa browser storage
                        localStorage.setItem('bhub_ad_last_shown', now);
                    }, 2000);
                }
            }
        });
    </script>
  
    @await RenderSectionAsync("Scripts", required: false)
</body>



</html>