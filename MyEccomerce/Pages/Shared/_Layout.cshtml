@using System.Security.Claims

@inject MyEccomerce.Data.ApplicationDbContext _context
@{
    
    var user = ViewBag.CurrentUser as MyEccomerce.Models.User;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isAuthenticated = User.Identity.IsAuthenticated;
    var firstName = User.FindFirstValue(ClaimTypes.GivenName) ?? User.Identity.Name;
   

    var profilePicClaim = User.FindFirst("ProfilePicture")?.Value;

    // Butangan og fallback kung null o empty ang sulod sa claim aron dili mabuak ang image tag
    var profilePic = !string.IsNullOrEmpty(profilePicClaim) ? profilePicClaim : "/images/default-avatar.png";
}
@{
    
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - B-HUB</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/MediaScreen.css"/>
    <link rel="stylesheet" href="~/css/Main.css"/>
    <link rel="stylesheet" href="~/css/MyOrders.css"/>
   
</head>
<body>
    <header class="main-header border-bottom shadow-sm sticky-top bg-white">
        <nav class="navbar navbar-light bg-white py-1 py-md-2">
            <div class="container d-flex align-items-center justify-content-between flex-nowrap">

                <!-- BRAND -->
                <!-- BRAND (Black & White Style) -->
                <a class="navbar-brand fw-bold flex-shrink-0 me-2 d-flex align-items-center" href="/" style="letter-spacing: -1.5px; font-size: 1.6rem; color: #000;">
                    <div class="action-icon-btn position-relative d-inline-flex align-items-center justify-content-center bg-primary"
                         style="width: 40px; height: 40px; line-height: 1;">
                        <i class="bi bi-house-door text-white " style="font-size: 1.3rem; line-height: 1; margin: 0; padding: 0;"></i>
                    </div>

                    <span class="d-none d-sm-inline text-dark ms-2" style="font-weight: 900;">B-HUB</span>
                </a>

                <!-- SEARCH WRAPPER (Full-screen Mobile Overlay) -->
                <form action="/Home" method="get" id="searchFormWrapper" class="search-wrapper flex-grow-1 mx-md-3">
                    <div class="search-container d-flex align-items-center border rounded-pill bg-light p-1 w-100">

                        <!-- Back Button (Mobile Only) -->
                        <button type="button" class="btn d-md-none border-0 text-muted ps-2" id="closeMobileSearch">
                            <i class="bi bi-arrow-left fs-4"></i>
                        </button>

                        <div class="position-relative flex-grow-1 d-flex align-items-center">
                            <!-- enterkeyhint="search" para "Search" ang mugawas sa keyboard -->
                            <input type="text" id="searchInput" name="q" autocomplete="off"
                                   enterkeyhint="search"
                                   class="form-control border-0 bg-transparent shadow-none ps-3 pe-5"
                                   placeholder="Pangita..."
                                   value="@ViewBag.SearchTerm"
                                   style="outline: none; font-size: 1rem; height: 40px;">

                            <!-- X (CLEAR) BUTTON -->
                            <button type="button" id="clearSearch" class="btn border-0 position-absolute end-0 me-2 text-muted"
                                    style="display: none; z-index: 5; padding: 0 8px;">
                                <i class="bi bi-x-lg" style="font-size: 1.1rem;"></i>
                            </button>
                        </div>

                        <!-- Button (Desktop Only: d-none d-md-flex) -->
                        <button type="submit" class="btn btn-primary rounded-pill px-3 shadow-sm d-none d-md-flex align-items-center justify-content-center ms-1">
                            
                            <span class="ms-2" style="font-size: 0.85rem; font-weight: 600;">Pangita</span>
                        </button>
                    </div>
                    <!-- Suggestions Area -->
                    <div id="searchSuggestions" class="dropdown-menu shadow-none w-100 mt-1 border-0" style="display: none; border-radius: 0; max-height: 80vh; overflow-y: auto;"></div>
                </form>

                <!-- RIGHT ACTION ICONS -->
                <div class="d-flex align-items-center flex-shrink-0" id="headerActions">

                    <!-- 1. SEARCH TRIGGER (Mobile Only) -->
                    <button type="button" class="action-icon-btn d-md-none" id="mobileSearchTrigger">
                        <i class="bi bi-search"></i>
                    </button>

                    <!-- 2. CART (Updated Icon) -->
                    <a href="javascript:void(0)" id="cartTrigger" class="action-icon-btn position-relative">
                        <i class="bi bi-cart3"></i>

                        @{
                            // Kuhaon ang count gikan sa server-side variable
                            var initialCount = ViewBag.CartCount ?? 0;
                            // Kon 0 ang count, tagoan ang badge (display: none)
                            var displayStatus = (initialCount > 0) ? "block" : "none";
                        }

                        <span class="position-absolute badge rounded-pill bg-danger border border-white badge-custom"
                              id="cartBadgeCount"
                              style="display: @displayStatus;">
                            @initialCount
                        </span>
                    </a>




                    <!-- 3. NOTIFICATIONS -->
                   
                   

                    <!-- NOTIFICATION ICON -->
                    <div class="dropdown">
                        <a @* href="#" *@ href="/Notification/Notification" class="action-icon-btn position-relative no-caret" id="userNotifDropdown" @* data-bs-toggle="dropdown" *@>
                            <i class="bi bi-bell"></i>
                            @{
                                var notifCount = ViewBag.UnreadNotifCount ?? 0;
                                var showNotifBadge = notifCount > 0 ? "block" : "none";
                            }
                            <span class="position-absolute badge rounded-pill bg-danger border border-white badge-custom"
                                  id="userNotifBadgeCount" style="display: @showNotifBadge;">
                                @notifCount
                            </span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow mt-2 custom-notif-dropdown border-0" style="border-radius:15px; min-width:320px;">
                            <li class="dropdown-header border-bottom fw-bold text-dark p-3 fs-6">Update sa Order</li>

                            <!-- Dinhi i-inject sa JS ang mga notifications -->
                            <div id="userNotifItemsContainer" style="max-height: 400px; overflow-y: auto;">
                            <li><p class="text-center text-muted small my-4 italic">Loading updates...</p></li>
                    </div>

                    <li><hr class="dropdown-divider m-0"></li>
                    <li><a class="dropdown-item text-center py-3 small fw-bold text-primary" href="/Orders/MyOrders">Tan-awa Tanan</a></li>
                    </ul>
                </div>
                    
                

               <div class="dropdown border-start ms-2 ps-2">
    <a href="#" class="d-flex align-items-center text-decoration-none" id="userDropdown" data-bs-toggle="dropdown">
        
        <div class="position-relative d-inline-block">
            
            <div class="profile-img-container">
                @if (User.Identity.IsAuthenticated)
                {
                    // I-check kung ang claim nakuha ba ug kung wala ba kini nagdala sa default path
                    bool hasValidImage = !string.IsNullOrEmpty(profilePic) && profilePic != "/images/default-avatar.png";

                    if (hasValidImage)
                    {
                        <img src="@profilePic" class="profile-img-container rounded-circle border" width="38" height="38" style="object-fit: cover;">
                    }
                    else
                    {
                        // Kung empty o default, gamiton ang UI-Avatars gamit ang firstName
                        <img src="https://ui-avatars.com/api/?name=@(System.Net.WebUtility.UrlEncode(firstName))&background=0047AB&color=fff&size=128"
                             class="rounded-circle border" width="38" height="38" alt="Profile Initials">
                    }
                }
                else
                {
                    <img src="https://th.bing.com/th/id/OIP.rxYdFlnCC39K-0lFt0tcYQHaHa?w=216&h=216&c=7&r=0&o=7&pid=1.7&rm=3"
                         class="rounded-circle border" width="38" height="38" alt="Profile Initials">
                }
            </div>

            <div class="position-absolute bg-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" 
                 style="bottom: -2px; right: -4px; width: 17px; height: 17px; border: 1px solid #ced4da; z-index: 5;">
                <i class="bi bi-chevron-down text-dark fw-bold" style="font-size: 0.5rem; display: block; line-height: 1;"></i>
            </div>

        </div>
    </a>
    
    <ul class="dropdown-menu dropdown-menu-end shadow mt-2 border-0" style="border-radius: 12px; min-width: 200px;">
        @{
            string greeting = $"Hi, {firstName}"; // Default fallback
            
            if (User.Identity.IsAuthenticated)
            {
                // Kuhaon ang Gender gikan sa claim custom string
                var genderClaim = User.FindFirst("Gender")?.Value;

                if (!string.IsNullOrEmpty(genderClaim))
                {
                    if (genderClaim.Equals("male", StringComparison.OrdinalIgnoreCase))
                    {
                        greeting = $"Hi Sir, {firstName}";
                    }
                    else if (genderClaim.Equals("female", StringComparison.OrdinalIgnoreCase))
                    {
                        greeting = $"Hi Ma'am, {firstName}";
                    }
                }
            }
        }

        @if (User.Identity.IsAuthenticated)
        {
            <li class="px-3 py-2 small fw-bold border-bottom">@greeting</li>
            <li><a class="dropdown-item py-2" href="/Account/UserProfile/@currentUserId">My Profile</a></li>
            <li><a class="dropdown-item py-2" href="/Orders/MyOrders?status=@(ViewBag.CurrentOrderStatus ?? "Pending")"><i class="bi bi-receipt text-marie me-2"></i> My Order </a> </li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item py-2 text-danger" href="/Account/Logout">Logout</a></li>
        }
        else
        {
            <li><a class="dropdown-item py-2 text-danger" href="/Account/Signin">Signin</a></li>
        }
    </ul>
</div>
            
            </div>
        </nav>

        <style>
            .no-caret::after {
                display: none;
            }

            .action-icon-btn {
                background: #f0f2f5;
                border: none;
                border-radius: 50%;
                width: 45px;
                height: 45px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #050505;
                margin-left: 8px;
                transition: background 0.2s;
                text-decoration: none;
            }

                .action-icon-btn:hover {
                    background: #e4e6eb;
                    color: #000;
                }

                .action-icon-btn i {
                    font-size: 1.4rem;
                }

            .badge-custom {
                font-size: 0.65rem !important;
                top: 2px !important;
                right: 2px !important;
                padding: 0.35em 0.5em !important;
            }

            .profile-img-container img {
                object-fit: cover;
                border: 2px solid #f0f2f5;
            }

           
        </style>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const trigger = document.getElementById('mobileSearchTrigger');
                const close = document.getElementById('closeMobileSearch');
                const wrapper = document.getElementById('searchFormWrapper');
                const input = document.getElementById('searchInput');
                const clearBtn = document.getElementById('clearSearch');

                // Open Search
                if (trigger) {
                    trigger.addEventListener('click', function () {
                        wrapper.classList.add('active');
                        document.body.style.overflow = 'hidden';
                        setTimeout(() => input.focus(), 200);
                    });
                }

                // Close Search
                if (close) {
                    close.addEventListener('click', function () {
                        wrapper.classList.remove('active');
                        document.body.style.overflow = 'auto';
                    });
                }

                // X Button Toggle
                function toggleClear() {
                    clearBtn.style.display = input.value.length > 0 ? 'block' : 'none';
                }

                input.addEventListener('input', toggleClear);

                // Clear Input
                clearBtn.addEventListener('click', function () {
                    input.value = '';
                    toggleClear();
                    input.focus();
                });

                // Initial check for clear button (if value exists on load)
                toggleClear();
            });
        </script>
    </header>

    <div class="offcanvas offcanvas-end" tabindex="-1" id="cartSidebar">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title fw-bold">Imong Cart</h5>
            <button type="button" class="btn-close shadow-none" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body p-0">
            <div id="cartItemsContainer" class="p-3"></div>
        </div>
        <div class="offcanvas-footer p-3 border-top bg-light text-center">
            <div class="d-flex justify-content-between mb-2 px-2">
                <span>Total:</span>
                <span class="fw-bold text-primary" id="cartTotalAmount">₱0.00</span>
            </div>
            <button id="checkoutBtn" onclick="goToCheckout()" class="btn btn-primary w-100 fw-bold">Checkout</button>
        </div>
    </div>

    <div class="container mt-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <div class="modal fade" id="advertisementModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
